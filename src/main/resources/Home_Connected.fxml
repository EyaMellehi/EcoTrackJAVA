<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.HomeConnectedController"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #f6f7f6;">

    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ImageView fitWidth="55" fitHeight="55" preserveRatio="true">
                            <image>
                                <Image url="@/images/logoeco.png"/>
                            </image>
                        </ImageView>

                        <Label text="EcoTrack"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="25">
                    <Button fx:id="btnHome"
                            text="Home"
                            style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 18px;"/>

                    <Button fx:id="btnReport"
                            text="Report"
                            style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>

                    <Button fx:id="btnBlogs"
                            text="Blogs"
                            style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>

                    <Button fx:id="btnAssociations"
                            text="Associations"
                            style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>

                    <Button fx:id="btnRecycling"
                            text="Recycling"
                            onAction="#goToRecycling"
                            style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>

                    <Button fx:id="btnEvents"
                            text="Events"
                            style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>
                </HBox>

                <Region prefWidth="20"/>

                <!-- Notifications -->
                <MenuButton text="🔔"
                            style="-fx-background-color: #eef7ee; -fx-font-size: 16px;">
                    <items>
                        <MenuItem text="No new notifications"/>
                    </items>
                </MenuButton>

                <!-- Profile Menu -->
                <MenuButton text="👤"
                            style="-fx-background-color: #4da64f; -fx-text-fill: white; -fx-font-size: 16px;">
                    <items>
                        <MenuItem fx:id="menuProfile" text="Profile" onAction="#goToProfile"/>
                        <MenuItem fx:id="menuDonations" text="My donations" onAction="#goToDonations"/>
                        <MenuItem fx:id="menuLogout" text="Logout" onAction="#logout"/>
                    </items>
                </MenuButton>

            </children>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="30" style="-fx-background-color: #f6f7f6;">

                    <!-- HERO -->
                    <StackPane prefHeight="420">
                        <children>

                            <Pane style="-fx-background-image: url('/images/carousel-1.jpg');
                      -fx-background-size: cover;
                      -fx-background-repeat: no-repeat;
                      -fx-background-position: center center;"/>

                            <Pane style="-fx-background-color: rgba(46,125,50,0.45);"/>

                            <VBox alignment="CENTER" spacing="18">
                                <Label text="EcoTrack"
                                       style="-fx-text-fill: #32a852; -fx-font-size: 22px; -fx-font-weight: bold;"/>

                                <Label text="Keep your city cleaner,&#10;together."
                                       alignment="CENTER"
                                       style="-fx-text-fill: white; -fx-font-size: 54px; -fx-font-weight: bold;"/>

                                <Label text="Report an incident, join events, support associations, and declare recycling points."
                                       style="-fx-text-fill: white; -fx-font-size: 18px;"/>

                                <HBox alignment="CENTER" spacing="15">
                                    <Button text="Report an incident"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>

                                    <Button text="Recycling points"
                                            onAction="#goToRecycling"
                                            style="-fx-background-color: transparent; -fx-border-color: white; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>

                                    <Button text="Events"
                                            style="-fx-background-color: transparent; -fx-border-color: white; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>
                                </HBox>

                                <Label fx:id="lblWelcomeUser"
                                       text="Logged in"
                                       style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 6 14; -fx-text-fill: #1f5130; -fx-font-size: 12px;"/>
                            </VBox>

                        </children>
                    </StackPane>

                    <!-- INFO BLOCKS -->
                    <HBox alignment="CENTER" spacing="0">
                        <children>
                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25; -fx-border-color: #eeeeee;">
                                <Label text="Geolocation" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Select the exact point on the map (auto address)." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>

                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25; -fx-border-color: #eeeeee;">
                                <Label text="Transparent tracking" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Pending → In progress → Resolved / Collected." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>

                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25; -fx-border-color: #eeeeee;">
                                <Label text="Eco actions" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Events, associations, local announcements." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- EXPLORE -->
                    <VBox alignment="CENTER" spacing="15" style="-fx-padding: 40 0 10 0;">
                        <Label text="Explore" style="-fx-text-fill: #37a93d; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <Label text="What would you like to do?"
                               style="-fx-text-fill: #104b2c; -fx-font-size: 42px; -fx-font-weight: bold;"/>
                        <Label text="Quick access to the main features."
                               style="-fx-text-fill: #6b7280; -fx-font-size: 18px;"/>
                    </VBox>

                    <!-- ACTION CARDS -->
                    <FlowPane alignment="CENTER" hgap="20" vgap="20" style="-fx-padding: 20 40 30 40;">
                        <children>
                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Reports" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Report an environmental incident and track its status." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Recycling points" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Declare recyclable materials and follow the collection." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open"
                                        onAction="#goToRecycling"
                                        style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Announcements" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Read local announcements and updates based on your region." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Events" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Join eco events and earn points." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Associations" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Discover active associations and support them." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>
                        </children>
                    </FlowPane>

                    <!-- STATS -->
                    <HBox alignment="CENTER" spacing="80" style="-fx-background-color: #6d8f72; -fx-padding: 60 20;">
                        <children>
                            <VBox alignment="CENTER" spacing="10">
                                <Label text="5" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                                <Label text="Reports" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                            </VBox>

                            <VBox alignment="CENTER" spacing="10">
                                <Label text="5" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                                <Label text="Recycling" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                            </VBox>

                            <VBox alignment="CENTER" spacing="10">
                                <Label text="1" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                                <Label text="Associations" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                            </VBox>

                            <VBox alignment="CENTER" spacing="10">
                                <Label text="1" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                                <Label text="Events" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- CTA -->
                    <HBox alignment="CENTER_LEFT" spacing="40" style="-fx-background-color: #eaf5ea; -fx-padding: 35 60 35 60;">
                        <children>
                            <VBox spacing="10">
                                <Label text="Ready to help build a cleaner city?"
                                       style="-fx-text-fill: #104b2c; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                                <Label text="Report, participate, recycle — every action matters."
                                       style="-fx-text-fill: #6b7280; -fx-font-size: 18px;"/>
                            </VBox>

                            <Pane HBox.hgrow="ALWAYS"/>

                            <Button text="Report now"
                                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 14 28;"/>
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>