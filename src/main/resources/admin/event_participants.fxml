<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.admin.EventParticipantsController"
            prefWidth="920" prefHeight="560"
            styleClass="event-page">

    <stylesheets>
        <URL value="@../style.css"/>
    </stylesheets>

    <top>
        <VBox spacing="10" styleClass="topbar">
            <children>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Accueil" styleClass="card-sub"/>
                        <Label text=">" styleClass="card-sub"/>
                        <Label text="Gestion des evenements" styleClass="card-sub"/>
                        <Label text=">" styleClass="card-sub"/>
                        <Label fx:id="lblBreadcrumbEvent" text="Evenement" styleClass="event-card-title"/>
                        <Label text=">" styleClass="card-sub"/>
                        <Label text="Participations" styleClass="event-card-title"/>
                    </children>
                </HBox>
                <Label fx:id="lblTitle" text="Participations" styleClass="event-page-title"/>
                <Label fx:id="lblEventMeta" text="Événement : ..." styleClass="event-page-subtitle"/>
                <Label fx:id="lblInfo" text="Chargement..." styleClass="event-page-subtitle"/>
            </children>
        </VBox>
    </top>

    <center>
        <VBox style="-fx-padding: 16;">
            <children>
                <TableView fx:id="tableParticipants" VBox.vgrow="ALWAYS"
                           styleClass="event-table">
                    <columns>
                        <TableColumn fx:id="colIndex" text="#" prefWidth="50"/>
                        <TableColumn fx:id="colName" text="Citoyen" prefWidth="180"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                        <TableColumn fx:id="colPhone" text="Telephone" prefWidth="150"/>
                        <TableColumn fx:id="colDate" text="Date d'inscription" prefWidth="170"/>
                        <TableColumn fx:id="colStatus" text="Statut" prefWidth="130"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="410"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

</BorderPane>

