<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.admin.EventFormController"
            prefWidth="1000" prefHeight="720"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <VBox spacing="8" style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20"
                      style="-fx-background-color: white; -fx-padding: 16 20 16 20; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/logoeco.png"/>
                                    </image>
                                </ImageView>
                                <Label text="EcoTrack"
                                       style="-fx-text-fill: #2e7d32; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                            </children>
                        </HBox>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnHome" text="Home" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 16px;"/>
                        <Button text="Events Management" style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <VBox style="-fx-padding: 12 16 0 16;">
                    <children>
                        <Label text="Accueil > Gestion des evenements > Nouveau"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <children>
                                <Label fx:id="lblTitle" text="Nouvel evenement ecologique"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Button text="Retour" onAction="#cancel"
                                        style="-fx-background-color: transparent; -fx-border-color: #6b7280; -fx-text-fill: #374151;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="14" style="-fx-padding: 20;">
                    <children>
                        <Label fx:id="lblFormError" visible="false" managed="false"
                               style="-fx-background-color: #fee2e2; -fx-text-fill: #991b1b; -fx-padding: 10; -fx-background-radius: 6;"/>

                        <VBox spacing="8" style="-fx-background-color: #e8f1ff; -fx-padding: 12; -fx-background-radius: 8;">
                            <children>
                                <Label text="Suggestion IA (date/heure optimale)" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                                <Label fx:id="lblSuggestion" text="-" style="-fx-text-fill: #334155;"/>
                                <Button text="Appliquer" onAction="#applySuggestion"
                                        style="-fx-background-color: transparent; -fx-border-color: #2563eb; -fx-text-fill: #2563eb;"/>
                            </children>
                        </VBox>

                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Titre*"/>
                                <TextField fx:id="tfTitre" promptText="Titre evenement"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Lieu*"/>
                                <TextField fx:id="tfLieu" promptText="Lieu evenement"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Date debut*"/>
                                <DatePicker fx:id="dpDateDeb"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Heure debut* (HH:mm)"/>
                                <TextField fx:id="tfHeureDeb" promptText="09:00"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label text="Date fin*"/>
                                <DatePicker fx:id="dpDateFin"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label text="Heure fin* (HH:mm)"/>
                                <TextField fx:id="tfHeureFin" promptText="11:00"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <Label text="Capacite max*"/>
                                <TextField fx:id="tfCapaciteMax" promptText="50"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <Label text="Points gagnes*"/>
                                <TextField fx:id="tfPointGain" promptText="10"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="4">
                                <Label text="Statut*"/>
                                <ComboBox fx:id="cbStatut"/>
                            </VBox>


                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="5">
                                <Label text="Cover media ID (optionnel)"/>
                                <TextField fx:id="tfCoverMediaId"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="2">
                                <Label text="Description"/>
                                <TextArea fx:id="taDescription" prefRowCount="5" wrapText="true"/>
                            </VBox>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button text="Annuler" onAction="#cancel"
                                        style="-fx-background-color: #6b7280; -fx-text-fill: white;"/>
                                <Button fx:id="btnSubmit" text="Creer l'evenement" onAction="#saveEvent"
                                        style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>