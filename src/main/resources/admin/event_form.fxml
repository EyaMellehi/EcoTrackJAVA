<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.admin.EventFormController"
            prefWidth="1000" prefHeight="720"
            styleClass="event-page">

    <stylesheets>
        <URL value="@../style.css"/>
    </stylesheets>

    <top>
        <VBox spacing="8" styleClass="topbar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/logoeco.png"/>
                                    </image>
                                </ImageView>
                                <Label text="EcoTrack" styleClass="logo"/>
                            </children>
                        </HBox>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnHome" text="Home" styleClass="event-secondary-button"/>
                        <Button text="Events Management" styleClass="event-outline-button"/>
                    </children>
                </HBox>

                <VBox style="-fx-padding: 12 16 0 16;">
                    <children>
                <Label text="Accueil > Gestion des evenements > Nouveau" styleClass="event-page-subtitle"/>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <Label fx:id="lblTitle" text="Nouvel evenement ecologique" styleClass="event-page-title"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="Retour" onAction="#cancel" styleClass="event-outline-button"/>
                    </children>
                </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="14" styleClass="content">
                    <children>
                        <Label fx:id="lblFormError" visible="false" managed="false"
                               styleClass="event-alert"/>

                        <VBox spacing="8" styleClass="event-section">
                            <children>
                                <Label text="Suggestion IA (date/heure optimale)" styleClass="section-title"/>
                                <Label fx:id="lblSuggestion" text="-" styleClass="event-page-subtitle"/>
                                <Button text="Appliquer" onAction="#applySuggestion"
                                        styleClass="event-outline-button"/>
                            </children>
                        </VBox>

                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Titre*"/>
                                <TextField fx:id="tfTitre" promptText="Titre evenement"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Lieu*"/>
                                <TextField fx:id="tfLieu" promptText="Lieu evenement"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Date debut*"/>
                                <DatePicker fx:id="dpDateDeb"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Heure debut* (HH:mm)"/>
                                <TextField fx:id="tfHeureDeb" promptText="09:00"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label text="Date fin*"/>
                                <DatePicker fx:id="dpDateFin"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label text="Heure fin* (HH:mm)"/>
                                <TextField fx:id="tfHeureFin" promptText="11:00"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <Label text="Capacite max*"/>
                                <TextField fx:id="tfCapaciteMax" promptText="50"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <Label text="Points gagnes*"/>
                                <TextField fx:id="tfPointGain" promptText="10"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="4">
                                <Label text="Statut*"/>
                                <ComboBox fx:id="cbStatut"/>
                            </VBox>


                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="5">
                                <Label text="Cover media ID (optionnel)"/>
                                <TextField fx:id="tfCoverMediaId"/>
                            </VBox>

                            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="2">
                                <Label text="Description"/>
                                <TextArea fx:id="taDescription" prefRowCount="5" wrapText="true"/>
                            </VBox>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button text="Annuler" onAction="#cancel"
                                        styleClass="event-secondary-button"/>
                                <Button fx:id="btnSubmit" text="Creer l'evenement" onAction="#saveEvent"
                                        styleClass="event-primary-button"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

