<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.admin.EventsManagementController"
            prefWidth="1280" prefHeight="760"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <StackPane fx:id="navbarContainer"/>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 16;">

            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 4 0 4;">
                <children>
                    <Label text="Gestion des evenements"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="Nouvel evenement" onAction="#openCreateForm"
                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;"/>
                </children>
            </HBox>

            <GridPane hgap="10" vgap="8"
                      style="-fx-background-color: #f8fbf8; -fx-padding: 14 20 16 20; -fx-border-color: #e5efe5; -fx-border-width: 1; -fx-background-radius: 8; -fx-border-radius: 8;">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0">
                    <Label text="Recherche"/>
                    <TextField fx:id="tfSearch" promptText="Titre, lieu, description..."/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1">
                    <Label text="Statut"/>
                    <ComboBox fx:id="cbStatut"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="2">
                    <Label text="Tri"/>
                    <ComboBox fx:id="cbSort"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="3">
                    <Label text="Ordre"/>
                    <ComboBox fx:id="cbOrder"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="4">
                    <Label text=" "/>
                    <Button text="Filtrer" onAction="#filterEvents"
                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                </VBox>
            </GridPane>

            <TableView fx:id="tableEvents" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #dde7dd; -fx-border-radius: 12; -fx-padding: 4;">
                <columns>
                    <TableColumn fx:id="colId" text="#" prefWidth="60"/>
                    <TableColumn fx:id="colTitre" text="Titre" prefWidth="220"/>
                    <TableColumn fx:id="colLieu" text="Lieu" prefWidth="170"/>
                    <TableColumn fx:id="colDateDeb" text="Date debut" prefWidth="150"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="110"/>
                    <TableColumn fx:id="colParticipants" text="Participants" prefWidth="120"/>
                    <TableColumn fx:id="colCreateur" text="Createur" prefWidth="90"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="330"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>