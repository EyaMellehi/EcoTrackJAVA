<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.admin.AddCategoryController"
      prefWidth="1500" prefHeight="900"
      style="-fx-background-color: #f5f7fb;">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="240"
              style="-fx-background-color: #121b3a; -fx-padding: 26 0 26 0;">
            <children>
                <VBox spacing="8" style="-fx-padding: 0 24 24 24;">
                    <Label text="EcoTrack"
                           style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                </VBox>

                <Button text="Dashboard"
                        onAction="#goToDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 18px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT; -fx-padding: 16 24; -fx-pref-width: 240;"/>

                <Button text="Subscribers"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Municipal Agents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Field Agents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Categories"
                        onAction="#goToCategories"
                        style="-fx-background-color: #0d1530; -fx-text-fill: white; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>
            </children>
        </VBox>

        <!-- RIGHT -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f7fb;">
            <children>

                <HBox alignment="CENTER_RIGHT"
                      prefHeight="70"
                      style="-fx-background-color: white; -fx-padding: 0 18 0 18; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <MenuButton text="👤"
                                    style="-fx-background-color: #f3f4f6; -fx-font-size: 18px; -fx-background-radius: 6; -fx-padding: 8 12;">
                            <items>
                                <MenuItem text="Logout"/>
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <content>
                        <VBox spacing="24" style="-fx-padding: 26; -fx-background-color: #f5f7fb;">

                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="8">
                                        <Label text="Nouvelle catégorie"
                                               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                        <Label text="Créer une catégorie de recyclage."
                                               style="-fx-font-size: 16px; -fx-text-fill: #6b7280;"/>
                                    </VBox>

                                    <Pane HBox.hgrow="ALWAYS"/>

                                    <Button text="← Back"
                                            onAction="#backToCategories"
                                            style="-fx-background-color: white; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                                </children>
                            </HBox>

                            <HBox spacing="20">
                                <children>

                                    <!-- FORM -->
                                    <VBox spacing="18" prefWidth="900"
                                          style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                        <children>

                                            <Label text="Créer une catégorie"
                                                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                                            <Label text="Ex : Plastique, Papier, Métal..."
                                                   style="-fx-text-fill: #6b7280;"/>

                                            <GridPane hgap="20" vgap="16">
                                                <children>

                                                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6">
                                                        <Label text="Nom"/>
                                                        <TextField fx:id="tfNom" prefWidth="350"/>
                                                    </VBox>

                                                    <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6">
                                                        <Label text="Coefficient points (par kg)"/>
                                                        <TextField fx:id="tfCoefPoints" prefWidth="350"/>
                                                        <Label text="Ex: 2 = 2 points par kg, 3.5 = 3.5 points par kg"
                                                               style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                                                    </VBox>

                                                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" spacing="6">
                                                        <Label text="Description (optionnel)"/>
                                                        <TextArea fx:id="taDescription" prefHeight="120" wrapText="true"/>
                                                    </VBox>

                                                </children>
                                            </GridPane>

                                            <Separator/>

                                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                                <children>
                                                    <Button text="Cancel"
                                                            onAction="#backToCategories"
                                                            style="-fx-background-color: white; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-padding: 12 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>

                                                    <Button text="Create"
                                                            onAction="#saveCategory"
                                                            style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 12 18; -fx-background-radius: 8;"/>
                                                </children>
                                            </HBox>

                                        </children>
                                    </VBox>

                                    <!-- CONSEILS -->
                                    <VBox spacing="12" prefWidth="320"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                        <children>
                                            <Label text="Conseils"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <Label text="• Nom court et clair&#10;• Ajoute dans la description : acceptés/refusés&#10;• CoefPoints = gain par kg"
                                                   wrapText="true"
                                                   style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</HBox>