<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.admin.CategoriesController"
      prefWidth="1500" prefHeight="900"
      style="-fx-background-color: #f5f7fb;">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="240"
              style="-fx-background-color: #121b3a; -fx-padding: 26 0 26 0;">
            <children>

                <VBox spacing="8" style="-fx-padding: 0 24 24 24;">
                    <Label text="EcoTrack"
                           style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                </VBox>

                <Button text="Dashboard"
                        onAction="#goToDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 18px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT; -fx-padding: 16 24; -fx-pref-width: 240;"/>

                <Button text="Subscribers"
                        onAction="#goToSubscribers"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Municipal Agents"
                        onAction="#goToMunicipalAgents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Field Agents"
                        onAction="#goToFieldAgents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Categories"
                        onAction="#goToCategories"
                        style="-fx-background-color: #0d1530; -fx-text-fill: white; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Associations"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Events"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

            </children>
        </VBox>

        <!-- RIGHT SIDE -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f7fb;">
            <children>

                <!-- TOP BAR -->
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="70"
                      style="-fx-background-color: white; -fx-padding: 0 18 0 18; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Pane HBox.hgrow="ALWAYS"/>

                        <MenuButton text="👤" fx:id="menuAdmin"
                                    style="-fx-background-color: #f3f4f6; -fx-font-size: 18px; -fx-background-radius: 6; -fx-padding: 8 12;">
                            <items>
                                <MenuItem text="Logout" onAction="#logout"/>
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <!-- MAIN CONTENT -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <content>
                        <VBox spacing="24" style="-fx-padding: 26; -fx-background-color: #f5f7fb;">

                            <!-- PAGE HEADER -->
                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="8">
                                        <Label text="Catégories"
                                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                        <Label text="Liste des catégories de recyclage."
                                               style="-fx-font-size: 17px; -fx-text-fill: #6b7280;"/>
                                    </VBox>

                                    <Pane HBox.hgrow="ALWAYS"/>

                                    <Button text="+ Nouvelle catégorie"
                                            onAction="#goToAddCategory"
                                            style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 16; -fx-background-radius: 8;"/>
                                </children>
                            </HBox>

                            <!-- CARD -->
                            <VBox spacing="18"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">

                                <Label text="Liste des catégories"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>

                                <!-- FILTER -->
                                <HBox spacing="12" alignment="BOTTOM_LEFT">
                                    <children>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <Label text="Search" style="-fx-text-fill: #374151;"/>
                                            <TextField fx:id="tfSearch"
                                                       promptText="Nom ou description..."
                                                       style="-fx-pref-height: 38;"/>
                                        </VBox>

                                        <Button text="Filter"
                                                onAction="#filterCategories"
                                                style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 150; -fx-pref-height: 38; -fx-background-radius: 6;"/>

                                        <Button text="Reset"
                                                onAction="#resetCategories"
                                                style="-fx-background-color: white; -fx-border-color: #9ca3af; -fx-text-fill: #374151; -fx-pref-width: 150; -fx-pref-height: 38; -fx-background-radius: 6; -fx-border-radius: 6;"/>
                                    </children>
                                </HBox>

                                <!-- TABLE -->
                                <TableView fx:id="tableCategories" prefHeight="520">
                                    <columns>
                                        <TableColumn fx:id="colIndex" text="#" prefWidth="80"/>
                                        <TableColumn fx:id="colNom" text="NOM" prefWidth="260"/>
                                        <TableColumn fx:id="colCoef" text="COEF (PTS/KG)" prefWidth="180"/>
                                        <TableColumn fx:id="colDescription" text="DESCRIPTION" prefWidth="420"/>
                                        <TableColumn fx:id="colNbPoints" text="NB POINTS" prefWidth="150"/>
                                    </columns>
                                </TableView>

                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <children>
                                        <Button text="Voir"
                                                onAction="#showCategory"
                                                style="-fx-background-color: white; -fx-border-color: black; -fx-text-fill: black; -fx-background-radius: 6; -fx-border-radius: 6;"/>

                                        <Button text="Modifier"
                                                onAction="#editCategory"
                                                style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 6;"/>

                                        <Button text="Supprimer"
                                                onAction="#deleteCategory"
                                                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 6;"/>
                                    </children>
                                </HBox>

                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</HBox>