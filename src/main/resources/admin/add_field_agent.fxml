<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.admin.AddFieldAgentController"
      prefWidth="1500" prefHeight="900"
      style="-fx-background-color: #f5f7fb;">

    <children>

        <VBox prefWidth="240"
              style="-fx-background-color: #121b3a; -fx-padding: 26 0 26 0;">
            <children>
                <VBox spacing="8" style="-fx-padding: 0 24 24 24;">
                    <Label text="EcoTrack"
                           style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                </VBox>

                <Button text="Dashboard"
                        onAction="#goToDashboard"
                        style="-fx-background-color: #0d1530; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT; -fx-padding: 16 24; -fx-pref-width: 240;"/>

                <Button text="Subscribers"
                        onAction="#goToSubscribers"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Municipal Agents"
                        onAction="#goToMunicipalAgents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Field Agents"
                        onAction="#goToFieldAgents"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Categories"
                        onAction="#goToCategories"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Associations"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>

                <Button text="Events"
                        style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 17px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 24; -fx-pref-width: 240;"/>
            </children>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f7fb;">
            <children>

                <HBox alignment="CENTER_RIGHT"
                      prefHeight="70"
                      style="-fx-background-color: white; -fx-padding: 0 18 0 18; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                    <children>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <MenuButton text="👤" fx:id="menuAdmin"
                                    style="-fx-background-color: #f3f4f6; -fx-font-size: 18px; -fx-background-radius: 6; -fx-padding: 8 12;">
                            <items>
                                <MenuItem text="Logout" onAction="#logout"/>
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <VBox spacing="20" style="-fx-padding: 26;">
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <VBox spacing="8">
                                <Label text="Add Field Agent"
                                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                <Label text="Create a new field agent account and assign a region."
                                       style="-fx-text-fill: #6b7280; -fx-font-size: 16px;"/>
                            </VBox>

                            <Pane HBox.hgrow="ALWAYS"/>

                            <Button text="← Back"
                                    onAction="#backToFieldAgents"
                                    style="-fx-background-color: white; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                        </children>
                    </HBox>

                    <VBox spacing="18"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">

                        <Label text="Agent Information"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>

                        <GridPane hgap="28" vgap="16">
                            <children>

                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6">
                                    <Label text="Full Name"/>
                                    <TextField fx:id="tfName" prefWidth="420"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6">
                                    <Label text="Email"/>
                                    <TextField fx:id="tfEmail" prefWidth="420"/>
                                </VBox>

                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="6">
                                    <Label text="Password"/>
                                    <PasswordField fx:id="pfPassword" prefWidth="420"/>
                                    <Label text="Minimum 6 characters." style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6">
                                    <Label text="Phone (optional)"/>
                                    <TextField fx:id="tfPhone" prefWidth="420"/>
                                </VBox>

                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="6">
                                    <Label text="Region"/>
                                    <ComboBox fx:id="cbRegion" promptText="Choose a region" prefWidth="420"
                                              onAction="#onRegionChanged"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="6">
                                    <Label text="Delegation"/>
                                    <ComboBox fx:id="cbDelegation" promptText="Choose a region first" prefWidth="420"/>
                                </VBox>

                            </children>
                        </GridPane>

                        <CheckBox fx:id="chkActive" text="Active account"/>

                        <Separator/>

                        <HBox spacing="10">
                            <children>
                                <Button text="💾  Save"
                                        onAction="#saveFieldAgent"
                                        style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 18; -fx-background-radius: 8;"/>

                                <Button text="Cancel"
                                        onAction="#backToFieldAgents"
                                        style="-fx-background-color: white; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-padding: 12 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                            </children>
                        </HBox>

                    </VBox>
                </VBox>

            </children>
        </VBox>

    </children>
</HBox>