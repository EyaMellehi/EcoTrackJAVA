<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>

<?import javafx.scene.chart.PieChart?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.admin.AdminDashboardController"
      prefWidth="1500" prefHeight="900"
      style="-fx-background-color: #f5f7fb;">

    <children>

        <!-- SIDEBAR -->
        <VBox prefWidth="290" minWidth="290" maxWidth="290"
              style="-fx-background-color: linear-gradient(to bottom, #0f172a, #132043); -fx-padding: 24 14 24 14;">
            <children>

                <!-- HEADER -->
                <VBox spacing="4" style="-fx-padding: 10 14 20 14;">
                    <children>
                        <Label text="EcoTrack"
                               style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                        <Label text="Admin Dashboard"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                    </children>
                </VBox>

                <Separator style="-fx-opacity: 0.25; -fx-padding: 0 10 10 10;"/>

                <!-- MENU -->
                <VBox spacing="10" style="-fx-padding: 12 4 12 4;">
                    <children>

                        <Button text="Dashboard"
                                onAction="#goToDashboard"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Subscribers"
                                onAction="#goToSubscribers"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Municipal Agents"
                                onAction="#goToMunicipalAgents"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Field Agents"
                                onAction="#goToFieldAgents"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Categories"
                                onAction="#goToCategories"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Associations"
                                onAction="#goToAssociation"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Donation"
                                onAction="#goToDonation"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                    </children>
                </VBox>

                <Pane VBox.vgrow="ALWAYS"/>



            </children>
        </VBox>

        <!-- RIGHT SIDE -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f5f7fb;">
            <children>

                <!-- TOP BAR -->
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="70"
                      style="-fx-background-color: white; -fx-padding: 0 18 0 18; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
                    <children>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <MenuButton text="👤" fx:id="menuAdmin"
                                    style="-fx-background-color: #f3f4f6; -fx-font-size: 18px; -fx-background-radius: 6; -fx-padding: 8 12;">
                            <items>
                                <MenuItem text="Logout" onAction="#logout"/>
                            </items>
                        </MenuButton>

                    </children>
                </HBox>

                <!-- MAIN CONTENT -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <content>
                        <VBox spacing="24" style="-fx-padding: 26; -fx-background-color: #f5f7fb;">

                            <!-- PAGE HEADER -->
                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="8">
                                        <Label text="Dashboard"
                                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                        <Label text="Quick overview of accounts and activity."
                                               style="-fx-font-size: 17px; -fx-text-fill: #6b7280;"/>
                                    </VBox>

                                    <Pane HBox.hgrow="ALWAYS"/>

                                    <HBox alignment="CENTER_RIGHT" spacing="10">
                                        <children>
                                            <Button text="Subscribers"
                                                    onAction="#goToSubscribers"
                                                    style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-text-fill: #334155; -fx-font-size: 14px; -fx-padding: 10 16; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                                            <Button text="Municipal Agents"  onAction="#goToMunicipalAgents"
                                                    style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-text-fill: #334155; -fx-font-size: 14px; -fx-padding: 10 16; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                                            <Button text="Field Agents"
                                                    onAction="#goToFieldAgents"
                                                    style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 16; -fx-background-radius: 8;"/>
                                        </children>
                                    </HBox>
                                </children>
                            </HBox>

                            <!-- STATS -->
                            <HBox spacing="18">
                                <children>

                                    <VBox prefWidth="290"
                                          style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Subscribers" style="-fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                                            <Label fx:id="lblSubscribersCount" text="0"
                                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                            <Label text="Citizens accounts" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                            <Separator style="-fx-padding: 10 0 10 0;"/>
                                            <Hyperlink onAction="#goToSubscribers" text="View list →"/>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="290"
                                          style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Municipal Agents" style="-fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                                            <Label fx:id="lblMunicipalCount" text="0"
                                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                            <Label text="One per delegation" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                            <Separator style="-fx-padding: 10 0 10 0;"/>
                                            <Hyperlink   onAction="#goToMunicipalAgents" text="Manage →"/>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="290"
                                          style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Field Agents" style="-fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                                            <Label fx:id="lblFieldCount" text="0"
                                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                            <Label text="On ground activity" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                            <Separator style="-fx-padding: 10 0 10 0;"/>
                                            <Hyperlink onAction="#goToFieldAgents" text="Manage →"/>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="290"
                                          style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Events" style="-fx-text-fill: #64748b; -fx-font-size: 15px;"/>
                                            <Label fx:id="lblEventsCount" text="0"
                                                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                            <Label text="Published events" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                            <Separator style="-fx-padding: 10 0 10 0;"/>
                                            <Hyperlink text="Open events →"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>

                            <!-- TABLE + SUMMARY -->
                            <HBox spacing="20">
                                <children>

                                    <VBox prefWidth="900"
                                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>

                                            <HBox alignment="CENTER_LEFT"
                                                  style="-fx-padding: 18 20 16 20;">
                                                <children>
                                                    <VBox spacing="6">
                                                        <Label text="Top Citizens"
                                                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                                        <Label text="Citizens ranked by points."
                                                               style="-fx-text-fill: #6b7280;"/>
                                                    </VBox>

                                                    <Pane HBox.hgrow="ALWAYS"/>

                                                    <Button text="View all"
                                                            onAction="#goToSubscribers"
                                                            style="-fx-background-color: white; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                                                </children>
                                            </HBox>

                                            <TableView fx:id="tableSubscribers" prefHeight="430">
                                                <columns>
                                                    <TableColumn fx:id="colName" text="NAME" prefWidth="200"/>
                                                    <TableColumn fx:id="colEmail" text="EMAIL" prefWidth="280"/>
                                                    <TableColumn fx:id="colRegion" text="REGION" prefWidth="180"/>
                                                    <TableColumn fx:id="colPoints" text="POINTS" prefWidth="110"/>
                                                    <TableColumn fx:id="colStatus" text="STATUS" prefWidth="130"/>
                                                </columns>
                                            </TableView>
                                            <Pagination fx:id="paginationTopCitoyens"
                                                        maxPageIndicatorCount="5"
                                                        style="-fx-padding: 12 20 18 20;"/>

                                        </children>
                                    </VBox>

                                    <VBox prefWidth="360"
                                          spacing="16"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="System Summary"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <Label text="Quick health and actions."
                                                   style="-fx-text-fill: #6b7280;"/>

                                            <Separator/>

                                            <HBox alignment="CENTER_LEFT">
                                                <children>
                                                    <VBox spacing="4">
                                                        <Label text="Accounts"
                                                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                                                        <Label text="Total managed roles"
                                                               style="-fx-text-fill: #6b7280;"/>
                                                    </VBox>
                                                    <Pane HBox.hgrow="ALWAYS"/>
                                                    <Label text="OK"
                                                           style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-padding: 4 10; -fx-background-radius: 8;"/>
                                                </children>
                                            </HBox>

                                            <Button text="+  Add Municipal Agent"
                                                    onAction="#goToAddMunicipalAgent"
                                                    style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-pref-width: 320; -fx-padding: 12; -fx-background-radius: 8;"/>
                                            <Button text="+  Add Field Agent"
                                                    onAction="#goToAddFieldAgent"
                                                    style="-fx-background-color: transparent; -fx-border-color: #94a3b8; -fx-text-fill: #334155; -fx-font-size: 16px; -fx-pref-width: 320; -fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>
                            <!-- CHARTS -->
                            <HBox spacing="20">
                                <children>

                                    <VBox prefWidth="700"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Platform Overview"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <Label text="Global comparison of key entities."
                                                   style="-fx-text-fill: #6b7280;"/>

                                            <BarChart fx:id="barChartStats" categoryGap="20" prefHeight="320" legendVisible="false">
                                                <xAxis>
                                                    <CategoryAxis label="Category"/>
                                                </xAxis>
                                                <yAxis>
                                                    <NumberAxis label="Count"/>
                                                </yAxis>
                                            </BarChart>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="500"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Users Distribution"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <Label text="Breakdown by role."
                                                   style="-fx-text-fill: #6b7280;"/>

                                            <PieChart fx:id="pieChartUsers" prefHeight="320" labelsVisible="true"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>
                            <HBox spacing="20">
                                <children>

                                    <VBox prefWidth="700"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Signalements by Delegation"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <BarChart fx:id="barChartSignalementsDelegation" prefHeight="300" legendVisible="false">
                                                <xAxis>
                                                    <CategoryAxis label="Delegation"/>
                                                </xAxis>
                                                <yAxis>
                                                    <NumberAxis label="Count"/>
                                                </yAxis>
                                            </BarChart>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="500"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Recyclage by Status"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <PieChart fx:id="pieChartRecyclageStatut" prefHeight="300"/>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>

                            <HBox spacing="20">
                                <children>

                                    <VBox prefWidth="500"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Associations by Region"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <BarChart fx:id="barChartAssociationsRegion" prefHeight="300" legendVisible="false">
                                                <xAxis>
                                                    <CategoryAxis label="Region"/>
                                                </xAxis>
                                                <yAxis>
                                                    <NumberAxis label="Count"/>
                                                </yAxis>
                                            </BarChart>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="500"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Annonces by Category"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <PieChart fx:id="pieChartAnnoncesCategorie" prefHeight="300"/>
                                        </children>
                                    </VBox>

                                    <VBox prefWidth="500"
                                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">
                                        <children>
                                            <Label text="Events by Status"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>
                                            <BarChart fx:id="barChartEventsStatut" prefHeight="300" legendVisible="false">
                                                <xAxis>
                                                    <CategoryAxis label="Status"/>
                                                </xAxis>
                                                <yAxis>
                                                    <NumberAxis label="Count"/>
                                                </yAxis>
                                            </BarChart>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>

                        </VBox>

                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</HBox>