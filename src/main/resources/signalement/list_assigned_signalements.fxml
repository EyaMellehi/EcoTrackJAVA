<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.signalement.ListAssignedSignalementController"
            prefWidth="1500" prefHeight="900"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <VBox spacing="0">
            <children>
                <fx:include fx:id="navbarCitoyen" source="/components/navbar_citoyen.fxml"/>

                <StackPane prefHeight="240">
                    <children>

                        <ImageView fitHeight="240" preserveRatio="false" StackPane.alignment="CENTER">
                            <image>
                                <Image url="@/images/carousel-1.jpg"/>
                            </image>
                        </ImageView>

                        <Pane style="-fx-background-color: rgba(0,0,0,0.50);"/>

                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <Label text="Field Agent"
                                       style="-fx-text-fill: #7bed8d; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                                <Label text="Assigned Signalements"
                                       style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                <Label text="View assigned signalements, open details, and create intervention reports."
                                       wrapText="true"
                                       style="-fx-text-fill: #dcefdc; -fx-font-size: 18px;"/>
                            </children>
                        </VBox>

                    </children>
                </StackPane>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="24" style="-fx-padding: 28; -fx-background-color: #f6f7f6;">

                    <!-- STATS -->
                    <HBox spacing="18" alignment="CENTER">
                        <children>
                            <VBox prefWidth="250" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                                <Label text="Assigned signalements"
                                       style="-fx-font-size: 15px; -fx-text-fill: #6b7280;"/>
                                <Label fx:id="lblTotalReports"
                                       text="0"
                                       style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                            </VBox>

                            <VBox prefWidth="250" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                                <Label text="In progress"
                                       style="-fx-font-size: 15px; -fx-text-fill: #6b7280;"/>
                                <Label fx:id="lblInProgress"
                                       text="0"
                                       style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #0284c7;"/>
                            </VBox>

                            <VBox prefWidth="250" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                                <Label text="Resolved"
                                       style="-fx-font-size: 15px; -fx-text-fill: #6b7280;"/>
                                <Label fx:id="lblResolved"
                                       text="0"
                                       style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- FILTERS -->
                    <VBox spacing="16"
                          style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                        <children>

                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="5">
                                        <Label text="Filters"
                                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f3d23;"/>
                                        <Label text="Search and sort your assigned signalements."
                                               style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>
                                    </VBox>
                                </children>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <children>
                                    <TextField fx:id="tfSearch"
                                               promptText="Search by title, type, status or address..."
                                               prefWidth="430"
                                               style="-fx-background-color: #eef7ee; -fx-background-radius: 10; -fx-padding: 10 14;"/>

                                    <ComboBox fx:id="cbSort"
                                              promptText="Sort by"
                                              prefWidth="190"
                                              onAction="#sortSignalements"
                                              style="-fx-background-color: #f8faf8; -fx-background-radius: 10;"/>

                                    <Pane HBox.hgrow="ALWAYS"/>

                                    <Button text="Search"
                                            onAction="#searchSignalements"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 18;"/>

                                    <Button text="Refresh"
                                            onAction="#loadAssignedSignalements"
                                            style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 18;"/>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <!-- LIST -->
                    <VBox spacing="16"
                          style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                        <children>

                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <VBox spacing="5">
                                        <Label text="Assigned signalements list"
                                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f3d23;"/>
                                        <Label text="Open a signalement to see details or create/view its intervention report."
                                               style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>
                                    </VBox>
                                </children>
                            </HBox>

                            <FlowPane fx:id="reportsContainer"
                                      hgap="20"
                                      vgap="20"
                                      alignment="CENTER"
                                      prefWrapLength="1300"
                                      style="-fx-padding: 10 0 0 0;"/>
                        </children>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>