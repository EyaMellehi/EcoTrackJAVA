<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.signalement.ListSignalementController"
            prefWidth="1450" prefHeight="900"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <StackPane>
            <children>
                <fx:include fx:id="navbarCitoyen" source="/components/navbar_citoyen.fxml"/>
                <fx:include fx:id="navbarMunicipal" source="/components/navbar_municipal.fxml"/>
            </children>
        </StackPane>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="28" style="-fx-background-color: #f6f7f6;">

                    <!-- INTRO -->
                    <HBox spacing="35" alignment="CENTER" style="-fx-padding: 40 60 20 60;">
                        <children>

                            <VBox spacing="18" prefWidth="520">
                                <children>
                                    <Label text="EcoTrack"
                                           style="-fx-text-fill: #37a93d; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                                    <Label text="Report an Environmental&#10;Incident"
                                           style="-fx-text-fill: #104b2c; -fx-font-size: 42px; -fx-font-weight: bold;"/>

                                    <Label wrapText="true"
                                           text="Help your municipality improve urban cleanliness. With EcoTrack, you can report a geolocated environmental incident and track its progress transparently."
                                           style="-fx-text-fill: #6b7280; -fx-font-size: 16px;"/>

                                    <VBox spacing="14">
                                        <children>
                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="1) Describe the incident"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Type, description, photo"
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="2) Locate it on the map"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Address / GPS"
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="3) Track the status"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Pending → In progress → Resolved"
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <Button text="⚑ Report now"
                                            onAction="#goToAddSignalement"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 14 24;"/>
                                </children>
                            </VBox>

                            <StackPane prefWidth="520" prefHeight="420">
                                <children>
                                    <ImageView fitWidth="520" fitHeight="420" preserveRatio="false">
                                        <image>
                                            <Image url="@/images/nat.jpg"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>

                        </children>
                    </HBox>

                    <!-- STATS -->
                    <HBox alignment="CENTER" spacing="120"
                          style="-fx-background-image: url('/images/carousel-1.jpg'); -fx-background-size: cover; -fx-background-position: center center; -fx-padding: 50 20;">
                        <children>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblTotalReports" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="Reports"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>

                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblInProgress" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="In progress"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>

                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblResolved" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="Resolved"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- MY REPORTS -->
                    <VBox spacing="14" style="-fx-padding: 20 60 40 60;">
                        <children>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label text="Tracking"
                                           style="-fx-text-fill: #37a93d; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                    <Label text="My reports"
                                           style="-fx-text-fill: #104b2c; -fx-font-size: 36px; -fx-font-weight: bold;"/>
                                    <Label text="You only see your own signalements."
                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 5 0 5 0;">
                                <children>
                                    <ComboBox fx:id="cbSort"
                                              promptText="Sort by"
                                              prefWidth="170"
                                              onAction="#sortSignalements"/>

                                    <TextField fx:id="tfSearch"
                                               promptText="Search by title, type, status or address..."
                                               prefWidth="360"
                                               style="-fx-background-color: white; -fx-padding: 10;"/>

                                    <Button text="Search"
                                            onAction="#searchSignalements"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>

                                    <Button text="Refresh"
                                            onAction="#loadMySignalements"
                                            style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827;"/>

                                    <Button text="+ Add Report"
                                            onAction="#goToAddSignalement"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 15px; -fx-padding: 10 18;"/>
                                </children>
                            </HBox>

                            <FlowPane fx:id="reportsContainer"
                                      hgap="20" vgap="20" alignment="CENTER"
                                      style="-fx-padding: 10 0 0 0;"/>
                        </children>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>