<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.Controllers.signalement.ShowSignalementController"
           prefWidth="1450" prefHeight="900"
           style="-fx-background-image: url('/images/carousel-1.jpg'); -fx-background-size: cover; -fx-background-position: center center;">

    <children>
        <Pane style="-fx-background-color: rgba(32,90,52,0.55);"/>

        <BorderPane maxWidth="950" maxHeight="820"
                    style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;">

            <top>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Report Details"
                                       style="-fx-text-fill: #104b2c; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                                <Label text="Detailed information about the selected signalement."
                                       style="-fx-text-fill: #7a8087; -fx-font-size: 14px;"/>
                            </children>
                        </VBox>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button text="Back"
                                onAction="#goBack"
                                style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 16px;"/>
                    </children>
                </HBox>
            </top>

            <center>
                <VBox spacing="18" style="-fx-padding: 20 0 0 0;">
                    <children>

                        <GridPane hgap="20" vgap="16"
                                  style="-fx-background-color: #f8faf8; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="28"/>
                                <ColumnConstraints percentWidth="72"/>
                            </columnConstraints>

                            <children>
                                <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblTitre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Description:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblDescription" wrapText="true" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Type:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblType" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Status:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblStatut" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Address:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblAddresse" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                                <Label text="Latitude:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblLatitude" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                                <Label text="Longitude:" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblLongitude" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                                <Label text="Created At:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblDateCreation" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                                <Label text="Delegation:" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblDelegation" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                                <Label text="Assigned Agent:" GridPane.rowIndex="9" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblAgentAssigneId" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                                <Label text="Assigned At:" GridPane.rowIndex="10" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblAssignedAt" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
                            </children>
                        </GridPane>

                        <VBox spacing="10">
                            <children>
                                <Label text="Photos"
                                       style="-fx-text-fill: #104b2c; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                <FlowPane fx:id="mediaContainer"
                                          hgap="16" vgap="16"
                                          prefWrapLength="880"/>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <children>
                                <Button text="View Report"
                                        onAction="#viewRapport"
                                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-padding: 10 18;"/>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</StackPane>