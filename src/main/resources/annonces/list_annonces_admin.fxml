<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.Controllers.annonces.ListAnnonceAdminController"
            prefWidth="1450" prefHeight="900" style="-fx-background-color: #f6f7f6;">

    <top>
        <fx:include fx:id="navbar" source="/components/navbar_municipal.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="25.0" style="-fx-background-color: #f6f7f6; -fx-padding: 40 60 40 60;">

                    <HBox spacing="30.0" alignment="CENTER_LEFT">
                        <Label text="📰 Gestion des Annonces" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #104b2c;" HBox.hgrow="ALWAYS" />
                        <Button text="➕ Ajouter une Annonce" style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-padding: 12 24;" onAction="#addNewAnnonce" />
                    </HBox>

                    <VBox spacing="12.0" style="-fx-border-color: #ddd; -fx-border-radius: 8; -fx-padding: 20; -fx-background-color: white;">
                        <Label text="🔍 Filtrer et Rechercher" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #104b2c;" />

                        <HBox spacing="15.0" prefHeight="70.0">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label text="Rechercher par titre ou contenu" style="-fx-font-size: 12px; -fx-text-fill: #7a8087;" />
                                <TextField fx:id="tfSearchAnnonce" promptText="Entrez un mot-clé..." style="-fx-padding: 10; -fx-font-size: 13px;" />
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Catégorie" style="-fx-font-size: 12px; -fx-text-fill: #7a8087;" />
                                <ComboBox fx:id="cbCategorieFilter" style="-fx-padding: 10; -fx-font-size: 13px;" promptText="Toutes les catégories" />
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Région" style="-fx-font-size: 12px; -fx-text-fill: #7a8087;" />
                                <ComboBox fx:id="cbRegionFilter" style="-fx-padding: 10; -fx-font-size: 13px;" promptText="Toutes les régions" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label fx:id="lblTotalAnnonces" text="Total: 0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #104b2c;" />
                    </HBox>

                    <VBox fx:id="annonceListContainer" spacing="12.0" style="-fx-padding: 0;" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
