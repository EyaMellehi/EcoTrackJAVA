<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.Controllers.annonces.RecommendedAnnonceUserController"
            prefWidth="1500" prefHeight="950" style="-fx-background-color: #f6f7f6;">

    <top>
        <fx:include fx:id="navbar" source="/components/navbar_citoyen.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="24.0" style="-fx-background-color: #f6f7f6; -fx-padding: 36 56 44 56;">

                    <HBox spacing="18" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #eff6ff, #f8fbff); -fx-padding: 24; -fx-background-radius: 20; -fx-border-color: #bfdbfe; -fx-border-radius: 20;">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Recommandation IA - V1" style="-fx-text-fill: #2563eb; -fx-font-size: 16px; -fx-font-weight: bold;" />
                            <Label text="⭐ Annonces recommandées" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #104b2c;" wrapText="true" />
                            <Label text="Classement basé sur vos likes/dislikes, votre région et la récence des annonces." style="-fx-text-fill: #6b7280; -fx-font-size: 15px;" wrapText="true" />
                        </VBox>
                        <VBox spacing="6" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 18 22; -fx-background-radius: 18; -fx-border-color: #e5e7eb; -fx-border-radius: 18;">
                            <Label fx:id="lblTotalRecommendations" text="0" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #104b2c;" />
                            <Label text="annonces recommandées" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                        </VBox>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button text="← Retour aux annonces" onAction="#goBackToAllAnnonces" style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 10 18;"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <FlowPane fx:id="annonceCardsContainer" hgap="24" vgap="24" prefWrapLength="1380" style="-fx-padding: 0 0 10 0;" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

