<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.HomeController"
            prefWidth="1400" prefHeight="800"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ImageView fitWidth="55" fitHeight="55" preserveRatio="true">
                            <image>
                                <Image url="@/images/logoeco.png"/>
                            </image>
                        </ImageView>

                        <Label text="EcoTrack"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>
                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="Home" onAction="#goToHome" style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 18px;"/>
                <Button text="Report" onAction="#goToReport" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>
                <Button text="Blogs" onAction="#goToBlogs" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>
                <Button text="Associations" onAction="#goToAssociation" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>
                <Button text="Recycling" onAction="#goToRecycling" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>
                <Button text="Events" onAction="#goToEvents" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 18px;"/>

                <Button text="Login" fx:id="btnLogin"
                        onAction="#goToLogin"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 12 24;"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <content>
                <VBox spacing="30" style="-fx-background-color: #f5f5f5;">

                    <StackPane prefHeight="400">
                        <children>

                            <Pane style="-fx-background-image: url('/images/carousel-1.jpg');
                      -fx-background-size: cover;
                      -fx-background-repeat: no-repeat;
                      -fx-background-position: center center;"/>

                            <Pane style="-fx-background-color: rgba(46,125,50,0.45);"/>

                            <VBox alignment="CENTER" spacing="20">
                                <Label text="EcoTrack"
                                       style="-fx-text-fill: #37a93d; -fx-font-size: 22px; -fx-font-weight: bold;"/>

                                <Label text="Keep your city cleaner,&#10;together."
                                       alignment="CENTER"
                                       style="-fx-text-fill: white; -fx-font-size: 54px; -fx-font-weight: bold;"/>

                                <Label text="Report an incident, join events, support associations, and declare recycling points."
                                       style="-fx-text-fill: white; -fx-font-size: 18px;"/>

                                <HBox alignment="CENTER" spacing="15">
                                    <Button text="Report an incident"
                                            onAction="#goToReport"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>
                                    <Button text="Recycling points"
                                            onAction="#goToRecycling"
                                            style="-fx-background-color: transparent; -fx-border-color: white; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>
                                    <Button text="Events"
                                            onAction="#goToEvents"
                                            style="-fx-background-color: transparent; -fx-border-color: white; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 12 24;"/>
                                </HBox>
                            </VBox>

                        </children>
                    </StackPane>

                    <HBox spacing="0" alignment="CENTER">
                        <children>
                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Geolocation" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Select the exact point on the map (auto address)." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>

                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Transparent tracking" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Pending → In progress → Resolved / Collected." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>

                            <VBox prefWidth="400" spacing="10" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Eco actions" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Events, associations, local announcements." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                            </VBox>
                        </children>
                    </HBox>

                    <VBox alignment="CENTER" spacing="15" style="-fx-padding: 50 0 10 0;">
                        <Label text="Explore" style="-fx-text-fill: #37a93d; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="What would you like to do?"
                               style="-fx-text-fill: #104b2c; -fx-font-size: 42px; -fx-font-weight: bold;"/>
                        <Label text="Quick access to the main features."
                               style="-fx-text-fill: #6b7280; -fx-font-size: 18px;"/>
                    </VBox>

                    <FlowPane alignment="CENTER" hgap="20" vgap="20" style="-fx-padding: 20 40 40 40;">
                        <children>
                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Reports" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Report an environmental incident and track its status." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" onAction="#goToReport" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Recycling points" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Declare recyclable materials and follow the collection." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" onAction="#goToRecycling" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Announcements" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Read local announcements and updates based on your region." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" onAction="#goToBlogs" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>

                            <VBox prefWidth="320" spacing="14" style="-fx-background-color: white; -fx-padding: 25;">
                                <Label text="Events" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #104b2c;"/>
                                <Label text="Join eco events and earn points." wrapText="true" style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
                                <Button text="Open" onAction="#goToEvents" style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>
                            </VBox>
                        </children>
                    </FlowPane>

                    <HBox alignment="CENTER_LEFT" spacing="40" style="-fx-background-color: #eaf5ea; -fx-padding: 35 60 35 60;">
                        <children>
                            <VBox spacing="10">
                                <Label text="Ready to help build a cleaner city?"
                                       style="-fx-text-fill: #104b2c; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                                <Label text="Report, participate, recycle — every action matters."
                                       style="-fx-text-fill: #6b7280; -fx-font-size: 18px;"/>
                            </VBox>

                            <Pane HBox.hgrow="ALWAYS"/>

                            <Button text="Create an account"
                                    onAction="#goToRegister"
                                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 14 28;"/>

                            <Button text="Sign in"
                                    onAction="#goToLogin"
                                    style="-fx-background-color: transparent; -fx-border-color: #2e7d32; -fx-text-fill: #2e7d32; -fx-font-size: 18px; -fx-padding: 14 28;"/>
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>