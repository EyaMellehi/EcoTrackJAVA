<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.AfficherDetailsAnnonce"
      style="-fx-background-color: #f5f5f5;">
    <VBox spacing="20" style="-fx-padding: 30;">
        <!-- HEADER avec actions -->
        <VBox spacing="15">
            <HBox spacing="15" style="-fx-alignment: center-left;">
                <Label text="Détails de l'Annonce" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1976D2;" HBox.hgrow="ALWAYS"/>
                <Button text="✏️ Éditer" onAction="#editerAnnonce" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 20; -fx-border-radius: 5; -fx-cursor: hand;"/>
                <Button text="🗑️ Supprimer" onAction="#supprimerAnnonce" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 20; -fx-border-radius: 5; -fx-cursor: hand;"/>
            </HBox>
            <Separator style="-fx-border-color: #e0e0e0;"/>
        </VBox>
        <!-- INFO CARD -->
        <VBox spacing="12" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 20; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <HBox spacing="50">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Titre" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="titreLabel" text="N/A" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Région" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="regionLabel" text="N/A" style="-fx-font-size: 14px; -fx-text-fill: #1976D2;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Catégorie" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="categorieLabel" text="N/A" style="-fx-font-size: 14px; -fx-text-fill: #2e7d32;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Date" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                    <Label fx:id="dateLabel" text="N/A" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                </VBox>
            </HBox>
        </VBox>
        <!-- CONTENU CARD -->
        <VBox spacing="10" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 20; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="Description" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <TextArea fx:id="contenuArea" prefHeight="120" wrapText="true" style="-fx-control-inner-background: #fafafa; -fx-font-size: 12px; -fx-padding: 10;"/>
        </VBox>
        <!-- IMAGE CARD -->
        <VBox spacing="10" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 20; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="Photo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <VBox style="-fx-alignment: center; -fx-border-color: #f0f0f0; -fx-border-radius: 5; -fx-background-color: #f9f9f9; -fx-padding: 15;">
                <ImageView fx:id="mediaImageView" fitHeight="280" fitWidth="450" preserveRatio="true" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 5, 0, 0, 2);"/>
                <Label fx:id="mediaInfoLabel" text="Aucune image" style="-fx-text-fill: #999; -fx-font-size: 12px; -fx-alignment: center; -fx-padding: 10;"/>
            </VBox>
        </VBox>
        <!-- COMMENTAIRES HEADER -->
        <HBox spacing="10" style="-fx-alignment: center-left;">
            <Label text="💬 Commentaires" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1976D2;"/>
            <Label fx:id="commentCountLabel" text="(0)" style="-fx-font-size: 14px; -fx-text-fill: #999;"/>
        </HBox>
        <!-- LISTE COMMENTAIRES -->
        <ListView fx:id="commentairesListView" prefHeight="300" style="-fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
        <!-- AJOUTER COMMENTAIRE CARD -->
        <VBox spacing="12" style="-fx-border-color: #2e7d32; -fx-border-radius: 8; -fx-border-width: 2; -fx-padding: 20; -fx-background-color: #f1f8e9; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <Label text="✍️ Ajouter un Commentaire" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
            <TextArea fx:id="texteCommentaireField" prefHeight="80" wrapText="true" promptText="Écrivez votre commentaire ici..." style="-fx-control-inner-background: white; -fx-font-size: 12px; -fx-padding: 10; -fx-border-radius: 5;"/>
            <Button text="✅ Ajouter" onAction="#ajouterCommentaire" style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 10 25; -fx-border-radius: 5; -fx-cursor: hand;"/>
        </VBox>
        <!-- FOOTER BUTTONS -->
        <HBox spacing="10" style="-fx-alignment: center;">
            <Button text="← Retour à la liste" onAction="#retournerAuListe" style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 30; -fx-border-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</ScrollPane>