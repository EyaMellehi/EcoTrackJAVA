<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.EventsController"
            prefWidth="1400" prefHeight="800"
            style="-fx-background-color: #f5f5f5;">

    <top>
        <StackPane fx:id="navbarContainer"/>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f5f5f5;">
            <content>
                <VBox spacing="30" style="-fx-background-color: #f5f5f5; -fx-padding: 40;">

                    <!-- En-tête -->
                    <VBox alignment="CENTER" spacing="15" style="-fx-padding: 0 0 20 0;">
                        <Label text="Événements Écologiques"
                               style="-fx-text-fill: #104b2c; -fx-font-size: 42px; -fx-font-weight: bold;"/>
                        <Label text="Rejoignez nos initiatives environnementales et participez à un avenir durable."
                               style="-fx-text-fill: #6b7280; -fx-font-size: 16px;"/>
                        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15 0 0 0;">
                            <Label fx:id="lblPoints" text="Points: 0"
                                   style="-fx-background-color: #ffc107; -fx-text-fill: #000; -fx-padding: 10 15; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                            <Button text="Mon historique" fx:id="btnHistory" onAction="#goHistory"
                                    style="-fx-background-color: transparent; -fx-border-color: #2e7d32; -fx-text-fill: #2e7d32; -fx-font-size: 14px; -fx-padding: 8 16;"/>
                        </HBox>
                    </VBox>

                    <!-- Filtrage -->
                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 8;">
                        <Label text="Filtrer les événements"
                               style="-fx-text-fill: #104b2c; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <GridPane hgap="15" vgap="15" style="-fx-padding: 0;">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints />
                            </columnConstraints>

                            <!-- Recherche -->
                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label text="Recherche"
                                       style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="tfSearch" promptText="Titre, lieu, description..."
                                          style="-fx-padding: 10; -fx-font-size: 14px;"/>
                            </VBox>

                            <!-- Statut -->
                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label text="Statut"
                                       style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="cbStatut" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="publie" />
                                            <String fx:value="termine" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="publie" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Tri par -->
                            <VBox spacing="5" GridPane.columnIndex="2">
                                <Label text="Trier par"
                                       style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="cbSortBy" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="date_deb" />
                                            <String fx:value="titre" />
                                            <String fx:value="lieu" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="date_deb" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Ordre -->
                            <VBox spacing="5" GridPane.columnIndex="3">
                                <Label text="Ordre"
                                       style="-fx-text-fill: #666; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="cbOrder" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="ASC" />
                                            <String fx:value="DESC" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="ASC" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Bouton Filtrer -->
                            <Button text="Filtrer" fx:id="btnFilter" onAction="#filterEvents"
                                    GridPane.columnIndex="4"
                                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
                        </GridPane>
                    </VBox>

                    <!-- Grille d'événements -->
                    <VBox fx:id="eventsContainer" spacing="20">
                        <!-- Les événements seront ajoutés dynamiquement ici -->
                    </VBox>

                    <!-- Message vide -->
                    <VBox fx:id="emptyContainer" alignment="CENTER" spacing="15" style="-fx-padding: 80 0;">
                        <Label text="Aucun événement trouvé"
                               style="-fx-text-fill: #999; -fx-font-size: 20px;"/>
                        <Label text="Essayez de modifier vos critères de recherche"
                               style="-fx-text-fill: #999; -fx-font-size: 14px;"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

