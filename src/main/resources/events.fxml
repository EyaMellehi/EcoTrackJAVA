<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.EventsController"
            prefWidth="1400" prefHeight="800"
            styleClass="event-page">

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <!-- TOP: Barre de navigation -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ImageView fitWidth="55" fitHeight="55" preserveRatio="true">
                            <image>
                                <Image url="@/images/logoeco.png"/>
                            </image>
                        </ImageView>
                        <Label text="EcoTrack" styleClass="logo"/>
                    </children>
                </HBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="Home" fx:id="btnHome" onAction="#goHome" styleClass="event-secondary-button"/>
                <Button text="Events" styleClass="event-outline-button"/>
                <Button text="Blogs" styleClass="event-secondary-button"/>
                <Button text="Associations" styleClass="event-secondary-button"/>
                <Button text="Recycling" styleClass="event-secondary-button"/>

                <Button text="Profile" fx:id="btnProfile" onAction="#goProfile"
                        styleClass="event-secondary-button"/>

            </children>
        </HBox>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="event-page">
            <content>
                <VBox spacing="30" styleClass="content">

                    <!-- En-tête -->
                    <VBox alignment="CENTER" spacing="15" styleClass="event-hero">
                        <Label text="Événements Écologiques" styleClass="event-hero-title"/>
                        <Label text="Rejoignez nos initiatives environnementales et participez à un avenir durable."
                               styleClass="event-hero-subtitle"/>
                        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15 0 0 0;">
                            <Label fx:id="lblPoints" text="Points: 0" styleClass="event-chip"/>
                            <Button text="Mon historique" fx:id="btnHistory" onAction="#goHistory" styleClass="event-outline-button"/>
                        </HBox>
                    </VBox>

                    <!-- Filtrage -->
                    <VBox spacing="15" styleClass="event-filter-panel">
                        <Label text="Filtrer les événements" styleClass="section-title"/>
                        <GridPane hgap="15" vgap="15" style="-fx-padding: 0;">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints />
                            </columnConstraints>

                            <!-- Recherche -->
                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label text="Recherche" styleClass="card-sub"/>
                                <TextField fx:id="tfSearch" promptText="Titre, lieu, description..."
                                          style="-fx-padding: 10; -fx-font-size: 14px;"/>
                            </VBox>

                            <!-- Statut -->
                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label text="Statut" styleClass="card-sub"/>
                                <ComboBox fx:id="cbStatut" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="publie" />
                                            <String fx:value="termine" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="publie" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Tri par -->
                            <VBox spacing="5" GridPane.columnIndex="2">
                                <Label text="Trier par" styleClass="card-sub"/>
                                <ComboBox fx:id="cbSortBy" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="date_deb" />
                                            <String fx:value="titre" />
                                            <String fx:value="lieu" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="date_deb" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Ordre -->
                            <VBox spacing="5" GridPane.columnIndex="3">
                                <Label text="Ordre" styleClass="card-sub"/>
                                <ComboBox fx:id="cbOrder" style="-fx-padding: 10; -fx-font-size: 14px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="ASC" />
                                            <String fx:value="DESC" />
                                        </FXCollections>
                                    </items>
                                    <value>
                                        <String fx:value="ASC" />
                                    </value>
                                </ComboBox>
                            </VBox>

                            <!-- Bouton Filtrer -->
                            <Button text="Filtrer" fx:id="btnFilter" onAction="#filterEvents"
                                    GridPane.columnIndex="4"
                                    styleClass="event-primary-button"/>
                        </GridPane>
                    </VBox>

                    <!-- Grille d'événements -->
                    <VBox fx:id="eventsContainer" spacing="20">
                        <!-- Les événements seront ajoutés dynamiquement ici -->
                    </VBox>

                    <Pagination fx:id="paginationEvents"
                                maxPageIndicatorCount="7"
                                pageCount="1"
                                currentPageIndex="0"
                                styleClass="pagination"/>

                    <!-- Message vide -->
                    <VBox fx:id="emptyContainer" alignment="CENTER" spacing="15" styleClass="event-empty-state">
                        <Label text="Aucun événement trouvé" styleClass="show-title"/>
                        <Label text="Essayez de modifier vos critères de recherche" styleClass="event-hero-subtitle"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

