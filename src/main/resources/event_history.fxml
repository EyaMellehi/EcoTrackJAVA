<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.EventHistoryController"
            prefWidth="1200" prefHeight="760"
            styleClass="event-page">

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>

    <top>
        <VBox spacing="10" styleClass="topbar">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <children>
                        <Label text="Mon Historique d'Evenements" styleClass="event-hero-title"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button text="Home" onAction="#goHome" styleClass="event-secondary-button"/>
                    </children>
                </HBox>
                <Label fx:id="lblInfo" text="Consultez tous les evenements auxquels vous avez participe." styleClass="event-hero-subtitle"/>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="event-page">
            <content>
                <VBox spacing="14" styleClass="content">
                    <children>
                        <Button text="Retour aux evenements" onAction="#goBack" styleClass="event-outline-button"/>

                        <VBox spacing="10" styleClass="event-filter-panel">
                            <children>
                                <Label text="Rechercher et filtrer" styleClass="section-title"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                        <TextField fx:id="tfSearch" promptText="Titre ou lieu..." onKeyReleased="#applyFilters" HBox.hgrow="ALWAYS"/>
                                        <ComboBox fx:id="cbStatus" onAction="#applyFilters" prefWidth="170"/>
                                        <ComboBox fx:id="cbSort" onAction="#applyFilters" prefWidth="170"/>
                                        <Button text="Reinitialiser" onAction="#resetFilters" styleClass="event-secondary-button"/>
                                    </children>
                                </HBox>
                                <Label fx:id="lblSummary" text="0 resultat" styleClass="event-meta"/>
                            </children>
                        </VBox>

                        <VBox fx:id="emptyBox" alignment="CENTER" spacing="10" styleClass="event-empty-state">
                            <children>
                                <Label text="Vous n'avez pas encore participe a des evenements." styleClass="event-hero-subtitle"/>
                                <Button text="Decouvrir les evenements" onAction="#goBack" styleClass="event-primary-button"/>
                            </children>
                        </VBox>

                        <FlowPane fx:id="historyFlow" hgap="16" vgap="16" prefWrapLength="1120"/>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>

