<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.User.ForgotPasswordController"
      prefWidth="900" prefHeight="500">

    <StackPane prefWidth="450">
        <children>
            <Pane style="-fx-background-image: url('/images/nat.jpg');
                         -fx-background-size: cover;
                         -fx-background-repeat: no-repeat;
                         -fx-background-position: center center;"/>
            <Pane style="-fx-background-color: rgba(46,125,50,0.35);"/>

            <VBox alignment="BOTTOM_LEFT" spacing="10">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>
                <Label text="EcoTrack"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Recover your access"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="We’ll send you a reset code by email."
                       style="-fx-text-fill: white;"/>
            </VBox>
        </children>
    </StackPane>

    <VBox alignment="CENTER" spacing="15" prefWidth="450" style="-fx-background-color: white;">
        <Label text="Forgot your password?"
               style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Enter your email"
               style="-fx-text-fill: gray;"/>

        <TextField fx:id="tfEmail" promptText="name@example.com" prefWidth="280"/>

        <Button text="Send Reset Code"
                onAction="#sendResetCode"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>

        <Hyperlink text="Back to login" onAction="#goToLogin"/>
    </VBox>

</HBox>