<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.User.FaceEnrollController"
      alignment="CENTER"
      spacing="18"
      prefWidth="700"
      prefHeight="600"
      style="-fx-background-color: white; -fx-padding: 30;">

    <children>
        <Label text="Activate Face Login"
               style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

        <Label text="Open the camera and take a clear face photo"
               style="-fx-text-fill: #667085; -fx-font-size: 15px;"/>

        <ImageView fx:id="cameraView"
                   fitWidth="420"
                   fitHeight="300"
                   preserveRatio="true"
                   style="-fx-border-color: #d0d5dd; -fx-border-radius: 8;"/>

        <Label fx:id="lblStatus"
               text=""
               style="-fx-text-fill: #2e7d32;"/>

        <HBox spacing="12" alignment="CENTER">
            <children>
                <Button text="Open Camera"
                        onAction="#openCamera"
                        prefWidth="140"/>

                <Button text="Take Photo"
                        onAction="#capturePhoto"
                        prefWidth="140"/>

                <Button text="Save"
                        onAction="#saveFace"
                        prefWidth="140"/>
            </children>
        </HBox>

        <Button text="Back"
                onAction="#goBack"
                prefWidth="180"/>
    </children>
</VBox>