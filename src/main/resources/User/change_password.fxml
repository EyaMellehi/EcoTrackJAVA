<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.User.ChangePasswordController"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 18 24 18 24; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ImageView fitWidth="55" fitHeight="55" preserveRatio="true">
                            <image>
                                <Image url="@/images/logoeco.png"/>
                            </image>
                        </ImageView>

                        <Label text="EcoTrack"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="22">
                    <Button text="Home" style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 17px;"/>
                    <Button text="Report" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Blogs" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Associations" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Recycling" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Events" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                </HBox>

                <Region prefWidth="20"/>

                <MenuButton text="🔔"
                            style="-fx-background-color: #eef7ee; -fx-font-size: 16px;">
                    <items>
                        <MenuItem text="No new notifications"/>
                    </items>
                </MenuButton>

                <MenuButton text="👤" fx:id="menuProfile"
                            style="-fx-background-color: #4da64f; -fx-text-fill: white; -fx-font-size: 16px;">
                    <items>
                        <MenuItem text="Profile" onAction="#backToProfile"/>
                        <MenuItem text="Logout" onAction="#logout"/>
                    </items>
                </MenuButton>
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="24" style="-fx-padding: 40 0 0 0;">
            <children>

                <HBox prefWidth="700" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="8">
                            <Label text="Change Password"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #123b2c;"/>
                            <Label text="For your security, choose a strong password you don’t use elsewhere."
                                   style="-fx-text-fill: #667085; -fx-font-size: 16px;"/>
                        </VBox>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button text="← Back to Profile"
                                onAction="#backToProfile"
                                style="-fx-background-color: transparent; -fx-border-color: #123b2c; -fx-text-fill: #123b2c; -fx-font-size: 16px; -fx-padding: 10 18;"/>
                    </children>
                </HBox>

                <VBox prefWidth="700" maxWidth="700" spacing="16"
                      style="-fx-background-color: white; -fx-padding: 32; -fx-border-color: #e8e8e8; -fx-background-radius: 8; -fx-border-radius: 8;">
                    <children>

                        <VBox spacing="6">
                            <Label text="Current Password" style="-fx-font-size: 15px;"/>
                            <PasswordField fx:id="pfCurrentPassword" prefWidth="560"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="New Password" style="-fx-font-size: 15px;"/>
                            <PasswordField fx:id="pfNewPassword" prefWidth="560"/>
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Confirm New Password" style="-fx-font-size: 15px;"/>
                            <PasswordField fx:id="pfConfirmPassword" prefWidth="560"/>
                        </VBox>

                        <Button text="🔑  Update Password"
                                onAction="#updatePassword"
                                prefWidth="560"
                                style="-fx-background-color: #0f5132; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 12 18;"/>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>