<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.User.Setup2FAController"
      alignment="CENTER"
      spacing="16"
      prefWidth="600"
      prefHeight="600"
      style="-fx-background-color: white; -fx-padding: 30;">

    <children>
        <Label text="Set up Two-Factor Authentication"
               style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

        <Label text="Scan this QR code with Google Authenticator"
               style="-fx-text-fill: #667085; -fx-font-size: 15px;"/>

        <ImageView fx:id="imgQrCode"
                   fitWidth="250"
                   fitHeight="250"
                   preserveRatio="true"/>

        <Label text="If you cannot scan, use this secret key:"
               style="-fx-text-fill: #667085;"/>

        <Label fx:id="lblSecret"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <TextField fx:id="tfOtpCode"
                   promptText="Enter 6-digit code"
                   maxWidth="250"/>

        <Label fx:id="lblError"
               text=""
               style="-fx-text-fill: red;"/>

        <Button text="Verify and Enable"
                onAction="#verifyAndEnable"
                prefWidth="250"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>

        <Button text="Cancel"
                onAction="#goBack"
                prefWidth="250"/>
    </children>
</VBox>