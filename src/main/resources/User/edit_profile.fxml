<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.User.EditProfileController"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-padding: 18 24 18 24; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <ImageView fitWidth="55" fitHeight="55" preserveRatio="true">
                            <image>
                                <Image url="@/images/logoeco.png"/>
                            </image>
                        </ImageView>

                        <Label text="EcoTrack"
                               style="-fx-text-fill: #2e7d32; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <HBox alignment="CENTER" spacing="22">
                    <Button text="Home" style="-fx-background-color: transparent; -fx-text-fill: #2e7d32; -fx-font-size: 17px;"/>
                    <Button text="Report" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Blogs" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Associations" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Recycling" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                    <Button text="Events" style="-fx-background-color: transparent; -fx-text-fill: #1f5130; -fx-font-size: 17px;"/>
                </HBox>

                <Region prefWidth="20"/>

                <MenuButton text="🔔"
                            style="-fx-background-color: #eef7ee; -fx-font-size: 16px;">
                    <items>
                        <MenuItem text="No new notifications"/>
                    </items>
                </MenuButton>

                <MenuButton text="👤" fx:id="menuProfile"
                            style="-fx-background-color: #4da64f; -fx-text-fill: white; -fx-font-size: 16px;">
                    <items>
                        <MenuItem text="Profile" onAction="#backToProfile"/>
                        <MenuItem text="Logout" onAction="#logout"/>
                    </items>
                </MenuButton>
            </children>
        </HBox>
    </top>

    <center>
        <HBox alignment="TOP_CENTER" spacing="30" style="-fx-padding: 35 60 35 60;">
            <children>

                <!-- LEFT CARD -->
                <VBox prefWidth="260" spacing="18"
                      style="-fx-background-color: white; -fx-padding: 22; -fx-border-color: #e8e8e8; -fx-background-radius: 8; -fx-border-radius: 8;">

                    <VBox alignment="CENTER" spacing="12"
                          style="-fx-background-color: #f4f8f8; -fx-padding: 25;">
                        <Label fx:id="lblAvatar"
                               text="A"
                               style="-fx-background-color: #6b4637; -fx-text-fill: white; -fx-font-size: 40px; -fx-font-weight: bold; -fx-background-radius: 100; -fx-padding: 28 34;"/>
                        <Label fx:id="lblNamePreview"
                               text="USER NAME"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #123b2c;"/>
                        <Label fx:id="lblEmailPreview"
                               text="user@email.com"
                               style="-fx-text-fill: #667085; -fx-font-size: 14px;"/>

                        <HBox alignment="CENTER" spacing="8">
                            <Label text="Citizen"
                                   style="-fx-text-fill: white; -fx-background-color: #dbe7dc; -fx-padding: 6 10; -fx-background-radius: 20;"/>
                            <Label fx:id="lblRegionPreview"
                                   text="Region"
                                   style="-fx-text-fill: white; -fx-background-color: #2e7d32; -fx-padding: 6 10; -fx-background-radius: 20;"/>
                        </HBox>
                    </VBox>

                    <Separator/>

                    <Label text="Tip: Use a clear profile photo and keep your phone number up to date."
                           wrapText="true"
                           style="-fx-text-fill: #667085; -fx-font-size: 14px;"/>
                </VBox>

                <!-- RIGHT FORM -->
                <VBox prefWidth="620" spacing="20">

                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <VBox spacing="8">
                                <Label text="Edit Profile"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #123b2c;"/>
                                <Label text="Update your personal information and contact details."
                                       style="-fx-text-fill: #667085; -fx-font-size: 16px;"/>
                            </VBox>

                            <Pane HBox.hgrow="ALWAYS"/>

                            <Button text="← Back to Profile"
                                    onAction="#backToProfile"
                                    style="-fx-background-color: transparent; -fx-border-color: #123b2c; -fx-text-fill: #123b2c; -fx-font-size: 16px; -fx-padding: 10 18;"/>
                        </children>
                    </HBox>

                    <VBox spacing="18"
                          style="-fx-background-color: white; -fx-padding: 24; -fx-border-color: #e8e8e8; -fx-background-radius: 8; -fx-border-radius: 8;">

                        <GridPane hgap="20" vgap="16">
                            <children>
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6">
                                    <Label text="Full Name"/>
                                    <TextField fx:id="tfName" promptText="Full name" prefWidth="220"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6">
                                    <Label text="Email"/>
                                    <TextField fx:id="tfEmail" promptText="Email" prefWidth="220"/>
                                </VBox>

                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="6">
                                    <Label text="Phone (optional)"/>
                                    <TextField fx:id="tfPhone" promptText="Phone" prefWidth="220"/>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6">
                                    <Label text="Region"/>
                                    <ComboBox fx:id="cbRegion" promptText="Region" prefWidth="220"/>
                                </VBox>
                            </children>
                        </GridPane>

                        <VBox spacing="8"
                              style="-fx-background-color: #edf7ed; -fx-padding: 16; -fx-border-color: #d9ead9; -fx-background-radius: 6; -fx-border-radius: 6;">
                            <HBox>
                                <children>
                                    <Label text="Profile Photo"
                                           style="-fx-font-size: 16px; -fx-text-fill: #445;"/>
                                    <Pane HBox.hgrow="ALWAYS"/>
                                    <Label text="JPG/PNG/WEBP"
                                           style="-fx-text-fill: #667085;"/>
                                </children>
                            </HBox>

                            <HBox spacing="10">
                                <Button text="Choose File" onAction="#chooseImage"/>
                                <Label fx:id="lblImageName" text="No file selected" style="-fx-text-fill: #667085;"/>
                            </HBox>

                            <Label text="The admin cannot edit your photo; only you can."
                                   style="-fx-text-fill: #667085;"/>
                        </VBox>

                        <Separator/>

                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <Button text="Cancel"
                                    onAction="#backToProfile"
                                    style="-fx-background-color: transparent; -fx-border-color: #123b2c; -fx-text-fill: #123b2c; -fx-font-size: 16px; -fx-padding: 10 18;"/>

                            <Button text="Save Changes"
                                    onAction="#saveChanges"
                                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 18;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </children>
        </HBox>
    </center>

</BorderPane>