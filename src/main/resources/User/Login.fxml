<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.User.LoginController"
      prefWidth="1400" prefHeight="800"
      style="-fx-background-color: white;">

    <!-- LEFT SIDE -->
    <StackPane prefWidth="700" HBox.hgrow="ALWAYS">
        <children>

            <Pane style="-fx-background-image: url('/images/nat.jpg');
                         -fx-background-size: cover;
                         -fx-background-repeat: no-repeat;
                         -fx-background-position: center center;"/>

            <Pane style="-fx-background-color: rgba(46,125,50,0.35);"/>

            <VBox alignment="BOTTOM_LEFT" spacing="12">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <Label text="EcoTrack"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>

                <Label text="Welcome back 👋"
                       style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;"/>

                <Label text="Track your impact, earn points,&#10;and keep your city cleaner."
                       style="-fx-text-fill: white; -fx-font-size: 18px;"/>
            </VBox>

        </children>
    </StackPane>

    <!-- RIGHT SIDE -->
    <VBox alignment="CENTER" spacing="18" prefWidth="700"
          HBox.hgrow="ALWAYS"
          style="-fx-background-color: white; -fx-padding: 40;">

        <Label text="Sign in"
               style="-fx-font-size: 32px; -fx-font-weight: bold;"/>

        <Label text="Access your EcoTrack account"
               style="-fx-text-fill: gray; -fx-font-size: 16px;"/>

        <TextField fx:id="tfEmail"
                   promptText="you@example.com"
                   prefWidth="320"
                   maxWidth="320"
                   style="-fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;"/>

        <PasswordField fx:id="pfPassword"
                       promptText="Password"
                       prefWidth="320"
                       maxWidth="320"
                       style="-fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;"/>

        <Hyperlink text="Forgot password?" onAction="#goToForgotPassword"/>

        <Button text="Login"
                fx:id="btnLogin"
                onAction="#login"
                prefWidth="320"
                maxWidth="320"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 12 20;"/>

        <HBox alignment="CENTER" spacing="10"
              prefWidth="320" maxWidth="320"
              style="-fx-background-color: white;
             -fx-border-color: #d9d9d9;
             -fx-border-width: 1;
             -fx-border-radius: 10;
             -fx-background-radius: 10;
             -fx-padding: 12 20;">
            <children>
                <Button text="G"
                        disable="true"
                        style="-fx-background-color: transparent;
                       -fx-text-fill: #4285F4;
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;"/>
                <Button text="Continue with Google"
                        onAction="#loginWithGoogle"
                        style="-fx-background-color: transparent;
                       -fx-text-fill: #333333;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;"/>
            </children>
        </HBox>
        <HBox spacing="5" alignment="CENTER">
            <Label text="Don't have an account?"/>
            <Hyperlink fx:id="linkRegister" text="Register" onAction="#goToRegister"/>
        </HBox>

    </VBox>

</HBox>