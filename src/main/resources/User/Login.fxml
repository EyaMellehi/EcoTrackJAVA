<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.User.LoginController"
      prefWidth="900" prefHeight="500">

    <!-- LEFT SIDE -->
    <StackPane prefWidth="450">
        <children>

            <Pane style="-fx-background-image: url('/images/nat.jpg');
                      -fx-background-size: cover;
                      -fx-background-repeat: no-repeat;
                      -fx-background-position: center center;"/>

            <Pane style="-fx-background-color: rgba(46,125,50,0.35);"/>

            <VBox alignment="BOTTOM_LEFT" spacing="10">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <Label text="EcoTrack"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                <Label text="Welcome back 👋"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>

                <Label text="Track your impact, earn points,&#10;and keep your city cleaner."
                       style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            </VBox>

        </children>
    </StackPane>

    <!-- RIGHT SIDE -->
    <VBox alignment="CENTER" spacing="15" prefWidth="450" style="-fx-background-color: white;">

        <Label text="Sign in"
               style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

        <Label text="Access your EcoTrack account"
               style="-fx-text-fill: gray;"/>

        <!-- Email -->
        <TextField fx:id="tfEmail" promptText="you@example.com"
                   style="-fx-background-radius: 10; -fx-padding: 10;"/>

        <!-- Password -->
        <PasswordField fx:id="pfPassword" promptText="Password"
                       style="-fx-background-radius: 10; -fx-padding: 10;"/>
        <Hyperlink text="Forgot password?" onAction="#goToForgotPassword"/>

        <!-- Login button -->
        <Button text="Login"
                fx:id="btnLogin"
                onAction="#login"
                style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 10; -fx-padding: 10 20;"/>

        <!-- Link -->
        <HBox spacing="5" alignment="CENTER">
            <Label text="Don't have an account?"/>
            <Hyperlink fx:id="linkRegister" text="Register" onAction="#goToRegister"/>
        </HBox>

    </VBox>

</HBox>