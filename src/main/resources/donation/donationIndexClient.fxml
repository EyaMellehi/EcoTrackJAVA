<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.association.DonationIndexClientController"
            stylesheets="@../style.css"
            styleClass="root">

    <!-- ================= TOP ================= -->
    <top>
        <VBox>

            <children>

                <!-- SAME NAVBAR -->
                <fx:include fx:id="navbar"
                            source="/components/navbar_citoyen.fxml"/>

                <!-- FILTER BAR -->
                <HBox spacing="15"
                      alignment="CENTER_LEFT"
                      style="-fx-background-color:white;
                             -fx-padding:18;
                             -fx-border-color:#e5e7eb;
                             -fx-border-width:0 0 1 0;">

                    <TextField fx:id="searchField"
                               promptText="🔍 Search donor / association..."
                               onKeyReleased="#onSearch"
                               prefWidth="320"
                               style="-fx-background-radius:10;
                                      -fx-border-radius:10;
                                      -fx-padding:10;
                                      -fx-font-size:14px;"/>

                    <ComboBox fx:id="typeFilter"
                              onAction="#onFilter"
                              prefWidth="220"
                              promptText="Choose type"
                              style="-fx-background-radius:10;
                                     -fx-font-size:14px;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Donations Directory"
                           style="-fx-font-size:18px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1f5130;"/>

                </HBox>

            </children>

        </VBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>

        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="scroll">

            <content>

                <FlowPane fx:id="cardContainer"
                          hgap="25"
                          vgap="25"
                          alignment="CENTER"
                          prefWrapLength="1100"
                          styleClass="content"/>

            </content>

        </ScrollPane>

    </center>

    <!-- ================= BOTTOM ================= -->
    <bottom>

        <HBox spacing="20"
              alignment="CENTER"
              style="-fx-background-color:white;
                     -fx-padding:18;
                     -fx-border-color:#e5e7eb;
                     -fx-border-width:1 0 0 0;">

            <Button text="⬅ Previous"
                    onAction="#prevPage"
                    styleClass="btn-page"/>

            <Label fx:id="pageLabel"
                   text="1 / 1"
                   style="-fx-font-size:15px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#1f5130;"/>

            <Button text="Next ➡"
                    onAction="#nextPage"
                    styleClass="btn-page"/>

        </HBox>

    </bottom>

</BorderPane>