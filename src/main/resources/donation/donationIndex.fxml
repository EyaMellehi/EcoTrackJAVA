<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.association.DonationIndexController"
      prefWidth="1500" prefHeight="900"
      stylesheets="@../style.css"

      style="-fx-background-color: #f5f7fb;">

    <children>

        <!-- EXACT SAME SIDEBAR AS ASSOCIATION -->
        <!-- SIDEBAR -->
        <VBox prefWidth="290" minWidth="290" maxWidth="290"
              style="-fx-background-color: linear-gradient(to bottom, #0f172a, #132043); -fx-padding: 24 14 24 14;">
            <children>

                <!-- HEADER -->
                <VBox spacing="4" style="-fx-padding: 10 14 20 14;">
                    <children>
                        <Label text="EcoTrack"
                               style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                        <Label text="Admin Dashboard"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;"/>
                    </children>
                </VBox>

                <Separator style="-fx-opacity: 0.25; -fx-padding: 0 10 10 10;"/>

                <!-- MENU -->
                <VBox spacing="10" style="-fx-padding: 12 4 12 4;">
                    <children>

                        <Button text="Dashboard"
                                onAction="#goToDashboard"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Subscribers"
                                onAction="#goToSubscribers"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Municipal Agents"
                                onAction="#goToMunicipalAgents"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Field Agents"
                                onAction="#goToFieldAgents"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Categories"
                                onAction="#goToCategories"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Associations"
                                onAction="#goToAssociation"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                        <Button text="Donation"
                                onAction="#goToDonation"
                                style="-fx-background-color: transparent; -fx-text-fill: #dbe4ff; -fx-font-size: 15px; -fx-alignment: CENTER-LEFT; -fx-padding: 14 18; -fx-pref-width: 260; -fx-background-radius: 14; -fx-cursor: hand;"/>

                    </children>
                </VBox>

                <Pane VBox.vgrow="ALWAYS"/>



            </children>
        </VBox>

        <!-- RIGHT SIDE -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color: #f5f7fb;">

            <children>

                <!-- TOP BAR -->
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="70"
                      style="-fx-background-color: white; -fx-padding: 0 18 0 18; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">

                    <children>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <MenuButton text="👤"
                                    fx:id="menuAdmin"
                                    style="-fx-background-color: #f3f4f6; -fx-font-size: 18px; -fx-background-radius: 6; -fx-padding: 8 12;">

                            <items>
                                <MenuItem text="Logout"
                                          onAction="#logout"/>
                            </items>

                        </MenuButton>

                    </children>

                </HBox>

                <!-- CONTENT -->
                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent;">

                    <content>

                        <VBox spacing="24"
                              style="-fx-padding: 26; -fx-background-color: #f5f7fb;">

                            <!-- HEADER -->
                            <HBox alignment="CENTER_LEFT">

                                <children>

                                    <VBox spacing="8">
                                        <Label text="Donations"
                                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>

                                        <Label text="Liste des donations enregistrées."
                                               style="-fx-font-size: 17px; -fx-text-fill: #6b7280;"/>
                                    </VBox>

                                    <Pane HBox.hgrow="ALWAYS"/>

                                </children>

                            </HBox>

                            <!-- MAIN CARD -->
                            <VBox spacing="18"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e5e7eb;">

                                <Label text="Liste des donations"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2a44;"/>

                                <!-- FILTER -->
                                <HBox spacing="12" alignment="BOTTOM_LEFT">

                                    <children>

                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <Label text="Search"
                                                   style="-fx-text-fill: #374151;"/>

                                            <TextField fx:id="searchField"
                                                       promptText="Donateur ou association..."
                                                       onKeyReleased="#onSearch"
                                                       style="-fx-pref-height: 38;"/>
                                        </VBox>

                                        <VBox spacing="6">
                                            <Label text="Type"
                                                   style="-fx-text-fill: #374151;"/>

                                            <ComboBox fx:id="typeFilter"
                                                      onAction="#onFilter"
                                                      prefWidth="180"
                                                      style="-fx-pref-height:38;"/>
                                        </VBox>

                                        <Button text="Filter"
                                                onAction="#onFilter"
                                                style="-fx-background-color: #121b3a; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 140; -fx-pref-height: 38; -fx-background-radius: 6;"/>

                                        <Button text="Reset"
                                                 style="-fx-background-color: white; -fx-border-color: #9ca3af; -fx-text-fill: #374151; -fx-pref-width: 140; -fx-pref-height: 38; -fx-background-radius: 6; -fx-border-radius: 6;"/>

                                    </children>

                                </HBox>

                                <!-- KEEP CARDS -->
                                <ScrollPane fitToWidth="true"
                                            prefHeight="520">

                                    <content>
                                        <FlowPane fx:id="cardContainer"
                                                  hgap="20"
                                                  vgap="20"
                                                  prefWrapLength="1150"/>
                                    </content>

                                </ScrollPane>

                                <!-- PAGINATION -->
                                <HBox alignment="CENTER_RIGHT"
                                      spacing="10">

                                    <children>

                                        <Button text="⬅"
                                                onAction="#prevPage"
                                                style="-fx-background-color: white; -fx-border-color: black; -fx-text-fill: black; -fx-background-radius: 6; -fx-border-radius: 6;"/>

                                        <Label fx:id="pageLabel"
                                               text="Page 1 / 1"
                                               style="-fx-font-size:14px; -fx-font-weight:bold;"/>

                                        <Button text="➡"
                                                onAction="#nextPage"
                                                style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 6;"/>

                                    </children>

                                </HBox>

                            </VBox>

                        </VBox>

                    </content>

                </ScrollPane>

            </children>

        </VBox>

    </children>

</HBox>