<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.association.AssociationClientShow"
            stylesheets="@../style.css"
            styleClass="root">

    <!-- 🌿 HEADER -->
    <top>
        <HBox spacing="20" styleClass="navbar">
            <Label text="🌱 EcoTrack" styleClass="logo"/>
            <Label text="Détails Association" styleClass="page-title"/>
        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <HBox spacing="40" alignment="CENTER" styleClass="show-wrapper">

            <!-- 🖼 LEFT IMAGE -->
            <VBox alignment="CENTER" spacing="15">

                <StackPane styleClass="image-big-container">
                    <ImageView fx:id="logo"
                               fitWidth="180"
                               fitHeight="180"
                               preserveRatio="true"/>
                </StackPane>

                <Label fx:id="name" styleClass="show-title"/>

                <Label fx:id="status" styleClass="badge-active"/>





                <VBox alignment="CENTER"
                      spacing="8"
                      style="-fx-padding:15;
                             -fx-background-color:white;
                             -fx-background-radius:18;
                             -fx-border-color:#e5e7eb;
                             -fx-border-radius:18;">

                    <Label text="📱 Scanner QR"
                           style="-fx-font-size:14px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1f5130;"/>

                    <ImageView fx:id="qrImage"
                               fitWidth="170"
                               fitHeight="170"
                               preserveRatio="true"/>

                </VBox>


            </VBox>

            <!-- 📄 RIGHT DETAILS -->
            <VBox spacing="12" styleClass="details-box">

                <Label text="Informations" styleClass="section-title"/>

                <HBox spacing="10">
                    <Label text="📂 Type:" styleClass="label-title"/>
                    <Label fx:id="type"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="📝 Description:" styleClass="label-title"/>
                    <Label fx:id="description" wrapText="true"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="📍 Région:" styleClass="label-title"/>
                    <Label fx:id="region"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="📞 Téléphone:" styleClass="label-title"/>
                    <Label fx:id="tel"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="📧 Email:" styleClass="label-title"/>
                    <Label fx:id="email"/>
                </HBox>

                <HBox spacing="10">
                    <Label text="🏠 Adresse:" styleClass="label-title"/>
                    <Label fx:id="adresse" wrapText="true"/>
                </HBox>

                <HBox spacing="15">

                    <Button text="💚 Faire un don"
                            onAction="#openDonationForm"
                            styleClass="btn-donation"/>

                    <Button text="Fermer"
                            onAction="#close"
                            styleClass="btn-danger"/>

                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>