<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.association.AssocationClientIndex"
            stylesheets="@../style.css"
            styleClass="root">

    <top>
        <VBox>
            <children>

                <fx:include fx:id="navbar" source="/components/navbar_citoyen.fxml"/>

                <HBox spacing="15"
                      alignment="CENTER_LEFT"
                      style="-fx-background-color:white;
                             -fx-padding:18;
                             -fx-border-color:#e5e7eb;
                             -fx-border-width:0 0 1 0;">

                    <TextField fx:id="searchField"
                               promptText="🔍 Search association..."
                               onKeyReleased="#onSearch"
                               prefWidth="320"
                               style="-fx-background-radius:10;
                                      -fx-border-radius:10;
                                      -fx-padding:10;
                                      -fx-font-size:14px;"/>

                    <ComboBox fx:id="regionFilter"
                              onAction="#onFilter"
                              prefWidth="220"
                              promptText="Choose region"
                              style="-fx-background-radius:10;
                                     -fx-font-size:14px;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Associations Directory"
                           style="-fx-font-size:18px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1f5130;"/>

                </HBox>

            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    fitToHeight="true"
                    hbarPolicy="NEVER"
                    styleClass="scroll">

            <content>
                <FlowPane fx:id="cardContainer"
                          hgap="25"
                          vgap="25"
                          alignment="CENTER"
                          prefWrapLength="1100"
                          styleClass="content"/>
            </content>

        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="20"
              alignment="CENTER"
              style="-fx-background-color:white;
                     -fx-padding:18;
                     -fx-border-color:#e5e7eb;
                     -fx-border-width:1 0 0 0;">

            <Button text="⬅ Previous"
                    onAction="#prevPage"
                    styleClass="btn-page"/>

            <Label fx:id="pageLabel"
                   text="1 / 1"
                   style="-fx-font-size:15px;
                          -fx-font-weight:bold;
                          -fx-text-fill:#1f5130;"/>

            <Button text="Next ➡"
                    onAction="#nextPage"
                    styleClass="btn-page"/>

        </HBox>
    </bottom>

</BorderPane>