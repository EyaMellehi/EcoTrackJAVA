<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.Controllers.association.AssocationClientIndex"
           stylesheets="@../style.css"
           styleClass="root"
           fx:id="rootPane">

    <BorderPane prefWidth="1400"
                prefHeight="900">

        <!-- ================================================= -->
        <!-- TOP                                                -->
        <!-- ================================================= -->
        <top>
            <VBox>

                <children>

                    <fx:include fx:id="navbar"
                                source="/components/navbar_citoyen.fxml"/>

                    <!-- SEARCH BAR -->
                    <VBox spacing="12"
                          style="-fx-background-color:white;
                                 -fx-padding:18;
                                 -fx-border-color:#e5e7eb;
                                 -fx-border-width:0 0 1 0;">

                        <!-- FIRST ROW -->
                        <HBox spacing="15"
                              alignment="CENTER_LEFT">

                            <TextField fx:id="searchField"
                                       promptText="🤖 Search association by name..."
                                       onKeyReleased="#onSearch"
                                       prefWidth="330"
                                       style="-fx-background-radius:12;
                                              -fx-border-radius:12;
                                              -fx-border-color:#d1d5db;
                                              -fx-padding:10 14;
                                              -fx-font-size:14px;"/>

                            <ComboBox fx:id="regionFilter"
                                      onAction="#onFilter"
                                      prefWidth="220"
                                      promptText="Choose region"
                                      style="-fx-background-radius:12;
                                             -fx-font-size:14px;"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <VBox alignment="CENTER_RIGHT"
                                  spacing="2">

                                <Label text="Associations Directory"
                                       style="-fx-font-size:20px;
                                              -fx-font-weight:bold;
                                              -fx-text-fill:#14532d;"/>

                                <Label text="AI-powered recommendations"
                                       style="-fx-font-size:12px;
                                              -fx-text-fill:#64748b;"/>

                            </VBox>

                        </HBox>

                        <!-- SECOND ROW -->
                        <HBox spacing="12"
                              alignment="CENTER_LEFT">

                            <TextArea fx:id="aiDescribeField"
                                      promptText="💚 Describe your situation or what you want to donate..."
                                      prefRowCount="2"
                                      wrapText="true"
                                      prefWidth="900"
                                      style="-fx-background-radius:12;
                                             -fx-border-radius:12;
                                             -fx-border-color:#cbd5e1;
                                             -fx-font-size:14px;
                                             -fx-padding:10;"/>

                            <Button fx:id="aiDescribeBtn"
                                    text="🤖 Find Best Associations"
                                    style="-fx-background-color:#16a34a;
                                           -fx-text-fill:white;
                                           -fx-font-weight:bold;
                                           -fx-background-radius:12;
                                           -fx-padding:12 18;
                                           -fx-cursor:hand;"/>

                        </HBox>

                        <!-- AI RESPONSE UNDER INPUT -->
                        <Label fx:id="aiResponseLabel"
                               text=""
                               visible="false"
                               managed="false"
                               wrapText="true"
                               maxWidth="1100"
                               style="-fx-background-color:#ecfdf5;
                                      -fx-text-fill:#166534;
                                      -fx-font-size:14px;
                                      -fx-font-weight:bold;
                                      -fx-padding:12;
                                      -fx-background-radius:12;
                                      -fx-border-color:#bbf7d0;
                                      -fx-border-radius:12;"/>

                    </VBox>

                </children>

            </VBox>
        </top>

        <!-- ================================================= -->
        <!-- CENTER                                             -->
        <!-- ================================================= -->
        <center>

            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        styleClass="scroll">

                <content>

                    <FlowPane fx:id="cardContainer"
                              hgap="25"
                              vgap="25"
                              alignment="TOP_CENTER"
                              prefWrapLength="1100"
                              styleClass="content"
                              style="-fx-padding:25;"/>

                </content>

            </ScrollPane>

        </center>

        <!-- ================================================= -->
        <!-- BOTTOM                                             -->
        <!-- ================================================= -->
        <bottom>

            <HBox spacing="20"
                  alignment="CENTER"
                  style="-fx-background-color:white;
                         -fx-padding:18;
                         -fx-border-color:#e5e7eb;
                         -fx-border-width:1 0 0 0;">

                <Button text="⬅ Previous"
                        onAction="#prevPage"
                        styleClass="btn-page"
                        prefWidth="130"/>

                <Label fx:id="pageLabel"
                       text="1 / 1"
                       style="-fx-font-size:15px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#14532d;
                              -fx-background-color:#ecfdf5;
                              -fx-padding:8 18;
                              -fx-background-radius:30;"/>

                <Button text="Next ➡"
                        onAction="#nextPage"
                        styleClass="btn-page"
                        prefWidth="130"/>

            </HBox>

        </bottom>

    </BorderPane>

    <!-- LOADER -->
    <VBox fx:id="loadingBox"
          visible="false"
          managed="false"
          alignment="CENTER"
          spacing="14"
          style="-fx-background-color:rgba(255,255,255,0.85);">

        <ProgressIndicator fx:id="spinner"
                           prefWidth="90"
                           prefHeight="90"
                           style="-fx-progress-color:#16a34a;"/>

        <Label text="AI is analyzing associations..."
               style="-fx-font-size:15px;
                      -fx-font-weight:bold;
                      -fx-text-fill:#14532d;"/>

    </VBox>

</StackPane>