<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.recyclage.ShowRapportRecycCitoyenController"
            prefWidth="1200" prefHeight="850"
            style="-fx-background-color: #f6f7f6;">

    <center>
        <VBox spacing="22" style="-fx-padding: 32;">
            <children>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="8">
                            <Label text="Citoyen"
                                   style="-fx-text-fill: #2f9e44; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblTitle"
                                   text="Rapport - Point #0"
                                   style="-fx-text-fill: #123524; -fx-font-size: 30px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblAddress"
                                   text="-"
                                   style="-fx-text-fill: #6b7280; -fx-font-size: 15px;"/>
                        </VBox>

                        <Pane HBox.hgrow="ALWAYS"/>

                        <Button text="Retour au point"
                                onAction="#goBackToPoint"
                                style="-fx-background-color: white; -fx-border-color: #374151; -fx-text-fill: #374151; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                    </children>
                </HBox>

                <VBox spacing="18"
                      style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                    <children>

                        <HBox spacing="16">
                            <children>
                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Catégorie" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblCategorie" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Quantité déclarée" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblQuantiteDeclaree" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Statut" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblStatut" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="16">
                            <children>
                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Date création" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblDateCreation" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Date collecte" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblDateCollecte" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Quantité collectée" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblQuantiteCollectee" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="16">
                            <children>
                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Agent terrain" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblAgent" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Point attribué" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblPointAttribue" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox prefWidth="250" spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                                    <Label text="Temps de traitement" style="-fx-text-fill: #6b7280;"/>
                                    <Label fx:id="lblTempsTraitement" text="-" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                            <Label text="Description du point" style="-fx-text-fill: #6b7280;"/>
                            <Label fx:id="lblDescriptionPoint" text="-" wrapText="true" style="-fx-font-size: 16px;"/>
                        </VBox>

                        <VBox spacing="6" style="-fx-background-color: #edf7ee; -fx-padding: 16; -fx-background-radius: 10;">
                            <Label text="Commentaire du rapport" style="-fx-text-fill: #6b7280;"/>
                            <Label fx:id="lblCommentaire" text="-" wrapText="true" style="-fx-font-size: 16px;"/>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>