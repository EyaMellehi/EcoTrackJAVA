<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.recyclage.TerrainPointDetailsController"
            prefWidth="1500" prefHeight="950"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <VBox spacing="0">
            <children>

                <fx:include fx:id="navbarCitoyen" source="/components/navbar_citoyen.fxml"/>

                <StackPane prefHeight="220"
                           style="-fx-background-color: linear-gradient(to right, #335c38, #6a8f70);">
                    <children>
                        <VBox alignment="CENTER" spacing="10">
                            <children>
                                <Label text="Agent de terrain"
                                       style="-fx-text-fill: #6ed46e; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                                <Label text="Détails du point"
                                       style="-fx-text-fill: white; -fx-font-size: 46px; -fx-font-weight: bold;"/>
                                <Label fx:id="lblPointIdTop"
                                       text="Point: #0"
                                       style="-fx-text-fill: #dcefdc; -fx-font-size: 18px;"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="24" style="-fx-padding: 30; -fx-background-color: #f6f7f6;">

                    <VBox spacing="6">
                        <Label fx:id="lblPointTitle"
                               text="Point #0"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #0f3d23;"/>
                        <Label fx:id="lblAddress"
                               text="Adresse"
                               wrapText="true"
                               style="-fx-font-size: 15px; -fx-text-fill: #666;"/>
                    </VBox>

                    <HBox spacing="10">
                        <children>
                            <Button text="← Retour"
                                    onAction="#goBack"
                                    style="-fx-background-color: white; -fx-border-color: #374151; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                            <Button text="Open in Google Maps"
                                    onAction="#openGoogleMaps"
                                    style="-fx-background-color: white; -fx-border-color: #2563eb; -fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-border-radius: 8;"/>
                        </children>
                    </HBox>

                    <HBox spacing="18">
                        <children>

                            <VBox prefWidth="230" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                <Label text="Statut" style="-fx-text-fill: #667085;"/>
                                <Label fx:id="lblStatus" text="IN_PROGRESS"
                                       style="-fx-padding: 6 14; -fx-background-radius: 18; -fx-font-weight: bold;"/>
                            </VBox>

                            <VBox prefWidth="230" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                <Label text="Priorité IA" style="-fx-text-fill: #667085;"/>
                                <Label fx:id="lblAiPriority" text="None"
                                       style="-fx-padding: 6 14; -fx-background-radius: 18; -fx-font-weight: bold;"/>
                            </VBox>

                            <VBox prefWidth="230" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                <Label text="Score IA" style="-fx-text-fill: #667085;"/>
                                <Label fx:id="lblAiScore" text="-"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>
                            </VBox>

                            <VBox prefWidth="230" spacing="8"
                                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-color: #e5e7eb; -fx-border-radius: 14;">
                                <Label text="Quantité déclarée" style="-fx-text-fill: #667085;"/>
                                <Label fx:id="lblQuantity" text="-"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>
                            </VBox>

                        </children>
                    </HBox>

                    <HBox spacing="18">
                        <children>

                            <VBox prefWidth="360" spacing="12"
                                  style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                                <Label text="Informations générales"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>

                                <HBox spacing="8">
                                    <children>
                                        <Label text="Catégorie :" style="-fx-font-weight: bold; -fx-text-fill: #667085;"/>
                                        <Label fx:id="lblCategory" text="-" wrapText="true"/>
                                    </children>
                                </HBox>

                                <HBox spacing="8">
                                    <children>
                                        <Label text="Date :" style="-fx-font-weight: bold; -fx-text-fill: #667085;"/>
                                        <Label fx:id="lblDate" text="-" wrapText="true"/>
                                    </children>
                                </HBox>

                                <HBox spacing="8">
                                    <children>
                                        <Label text="Agent terrain :" style="-fx-font-weight: bold; -fx-text-fill: #667085;"/>
                                        <Label fx:id="lblFieldAgent" text="-" wrapText="true"/>
                                    </children>
                                </HBox>

                                <HBox spacing="8">
                                    <children>
                                        <Label text="Coordonnées :" style="-fx-font-weight: bold; -fx-text-fill: #667085;"/>
                                        <Label fx:id="lblCoordinates" text="-" wrapText="true"/>
                                    </children>
                                </HBox>
                            </VBox>

                            <VBox prefWidth="500" spacing="12"
                                  style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                                <Label text="Description du citoyen"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>
                                <Label fx:id="lblDescription"
                                       text="-"
                                       wrapText="true"
                                       style="-fx-background-color: #f8faf8; -fx-padding: 14; -fx-background-radius: 10; -fx-text-fill: #374151;"/>
                            </VBox>

                        </children>
                    </HBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                        <Label text="Estimation IA"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>
                        <Label fx:id="lblAiExplanation"
                               text="-"
                               wrapText="true"
                               style="-fx-background-color: #eef7ee; -fx-padding: 16; -fx-background-radius: 12; -fx-text-fill: #374151;"/>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                        <Label text="Localisation"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #123524;"/>
                        <WebView fx:id="webMap"
                                 prefWidth="900"
                                 prefHeight="360"
                                 minHeight="360"
                                 maxHeight="360"/>
                    </VBox>

                    <HBox spacing="12">
                        <children>
                            <Button fx:id="btnCreateReport"
                                    text="+ Créer le rapport de collecte"
                                    onAction="#createReport"
                                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 8;"/>
                            <Button fx:id="btnViewReport"
                                    text="Voir le rapport"
                                    onAction="#viewReport"
                                    style="-fx-background-color: #1e88e5; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 8;"/>
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>