<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.Controllers.recyclage.PointsConnectedController"
            prefWidth="1450" prefHeight="900"
            style="-fx-background-color: #f6f7f6;">

    <top>
        <fx:include fx:id="navbar" source="/components/navbar_citoyen.fxml"/>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="28" style="-fx-background-color: #f6f7f6;">

                    <!-- INTRO -->
                    <HBox spacing="35" alignment="CENTER" style="-fx-padding: 40 60 20 60;">
                        <children>

                            <VBox spacing="18" prefWidth="520">
                                <children>
                                    <Label text="EcoTrack"
                                           style="-fx-text-fill: #37a93d; -fx-font-size: 20px; -fx-font-weight: bold;"/>

                                    <Label text="Declare a Recycling&#10;Point"
                                           style="-fx-text-fill: #104b2c; -fx-font-size: 42px; -fx-font-weight: bold;"/>

                                    <Label wrapText="true"
                                           text="Declare your recyclable materials, follow their status, and help improve eco-collection in your city."
                                           style="-fx-text-fill: #6b7280; -fx-font-size: 16px;"/>

                                    <VBox spacing="14">
                                        <children>
                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="1) Choose the category"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Plastic, metal, paper..."
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="2) Add location"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Address / GPS"
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>

                                            <VBox spacing="4" style="-fx-border-color: transparent transparent transparent #d7e6d7; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 14;">
                                                <children>
                                                    <Label text="3) Track the status"
                                                           style="-fx-text-fill: #104b2c; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                                    <Label text="Pending → In progress → Collected"
                                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <Button text="+ New recycling point"
                                            onAction="#goToAddPoint"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 14 24;"/>
                                </children>
                            </VBox>

                            <StackPane prefWidth="520" prefHeight="420">
                                <children>
                                    <ImageView fitWidth="520" fitHeight="420" preserveRatio="false">
                                        <image>
                                            <Image url="@/images/carousel-1.jpg"/>
                                        </image>
                                    </ImageView>
                                </children>
                            </StackPane>

                        </children>
                    </HBox>

                    <!-- STATS -->
                    <HBox alignment="CENTER" spacing="120"
                          style="-fx-background-image: url('/images/carousel-1.jpg'); -fx-background-size: cover; -fx-background-position: center center; -fx-padding: 50 20;">
                        <children>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblTotal" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="Points"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>

                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblPending" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="Pending"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>

                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblInProgress" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="In progress"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>

                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label fx:id="lblCollecte" text="0"
                                           style="-fx-text-fill: white; -fx-font-size: 50px; -fx-font-weight: bold;"/>
                                    <Label text="Collected"
                                           style="-fx-text-fill: white; -fx-font-size: 22px;"/>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- MY POINTS -->
                    <VBox spacing="14" style="-fx-padding: 20 60 40 60;">
                        <children>
                            <VBox alignment="CENTER" spacing="8">
                                <children>
                                    <Label text="Tracking"
                                           style="-fx-text-fill: #37a93d; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                    <Label text="My recycling points"
                                           style="-fx-text-fill: #104b2c; -fx-font-size: 36px; -fx-font-weight: bold;"/>
                                    <Label text="You only see your own declared recycling points."
                                           style="-fx-text-fill: #7a8087; -fx-font-size: 15px;"/>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 5 0 5 0;">
                                <children>
                                    <ComboBox fx:id="cbStatus"
                                              promptText="All statuses"
                                              prefWidth="180"/>

                                    <TextField fx:id="tfSearch"
                                               promptText="Search by address, category or status..."
                                               prefWidth="360"
                                               style="-fx-background-color: white; -fx-padding: 10;"/>

                                    <Button text="Search"
                                            onAction="#filterPoints"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white;"/>

                                    <Button text="Refresh"
                                            onAction="#resetFilter"
                                            style="-fx-background-color: #e5e7eb; -fx-text-fill: #111827;"/>

                                    <Button text="+ Add Point"
                                            onAction="#goToAddPoint"
                                            style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 15px; -fx-padding: 10 18;"/>
                                </children>
                            </HBox>

                            <!-- TABLE GARDEE -->
                            <VBox spacing="12"
                                  style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 10;">
                                <children>
                                    <TableView fx:id="tablePoints" prefHeight="500">
                                        <columns>
                                            <TableColumn fx:id="colId" text="#" prefWidth="70"/>
                                            <TableColumn fx:id="colCategorie" text="Category" prefWidth="150"/>
                                            <TableColumn fx:id="colQuantite" text="Quantity" prefWidth="110"/>
                                            <TableColumn fx:id="colAddress" text="Address" prefWidth="380"/>
                                            <TableColumn fx:id="colDate" text="Date" prefWidth="130"/>
                                            <TableColumn fx:id="colStatut" text="Status" prefWidth="140"/>
                                            <TableColumn fx:id="colActions" text="Actions" prefWidth="240"/>
                                        </columns>
                                    </TableView>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>